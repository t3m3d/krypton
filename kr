#!/usr/bin/env bash
# kr — run a Krypton script (KryptScript), or start a REPL.
#
#   kr                      start the interactive REPL
#   kr script.ks [args...]  run a script (args forwarded to it)
#
# Shebang-friendly: put `#!/usr/bin/env kr` atop a .ks (or .k) file,
# `chmod +x` it, and run it like any other script.
#
# SWIFT-LIKE TOP-LEVEL CODE: if a script has no `just run { }` block, kr
# auto-wraps its whole body in one — write statements at the top of the
# file with no boilerplate. `import` and `func` work inside the wrap too.
# Scripts that already contain `just run` (or declare a `module`) run as-is.
#
# Script args are forwarded and visible via `arg(0)`, `arg(1)`, `argCount()`.

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# kcc.sh was removed in 0c0dc57b; the `kcc` driver owns `-r` now. Prefer a
# kcc next to this script (installed/tarball layout), else fall back to kcc
# on PATH (dev checkout, where kcc is installed via Homebrew).
KCC="$SCRIPT_DIR/kcc"
if [ ! -x "$KCC" ]; then KCC="$(command -v kcc)"; fi
if [ -z "$KCC" ]; then
    echo "kr: cannot find 'kcc' (not next to this script, not on PATH)" >&2
    exit 127
fi

# ── REPL ──────────────────────────────────────────────────────────────
# No real interpreter exists (Krypton compiles to native), so this is an
# accumulating REPL: `import`/`func`/`struct`/`let` entries are remembered
# and re-emitted around each new line, which is then compiled + run. Bare
# expressions run once (type `kp(expr)` to see a value). Multi-line blocks
# continue until braces balance.

_brace_delta() {  # echo (count of '{') - (count of '}') in $1
    local s="$1" o c
    o=$(printf '%s' "$s" | tr -cd '{' | wc -c | tr -d ' ')
    c=$(printf '%s' "$s" | tr -cd '}' | wc -c | tr -d ' ')
    echo $(( o - c ))
}

_repl() {
    local ver imports="" defs="" line more depth tmp err
    ver=$("$KCC" --version 2>/dev/null | awk '{print $NF}')
    echo "KryptScript REPL — Krypton ${ver:-?}  (:help, :q to quit)"
    err="${TMPDIR:-/tmp}/kr_repl_err_$$"
    while true; do
        printf 'ks> '
        IFS= read -r line || { echo; break; }   # EOF / Ctrl-D
        case "$line" in
            '') continue ;;
            ':q'|':quit'|':exit') break ;;
            ':help')
                echo "  Krypton expressions/statements run immediately."
                echo "  import/func/struct/let are remembered for later lines."
                echo "  :list  show remembered defs   :reset  clear them"
                echo "  :q     quit                   (Ctrl-D also quits)"
                continue ;;
            ':reset') imports=""; defs=""; echo "(state cleared)"; continue ;;
            ':list')
                [ -n "$imports" ] && printf '%s\n' "$imports"
                [ -n "$defs" ] && printf '%s\n' "$defs"
                [ -z "$imports$defs" ] && echo "(nothing remembered yet)"
                continue ;;
        esac
        # Multi-line continuation until braces balance.
        depth=$(_brace_delta "$line")
        while [ "$depth" -gt 0 ]; do
            printf '..> '
            IFS= read -r more || break
            line="$line"$'\n'"$more"
            depth=$(( depth + $(_brace_delta "$more") ))
        done
        # Build: imports (top) + just run { remembered defs; this line }.
        tmp="${TMPDIR:-/tmp}/kr_repl_$$.ks"
        {
            [ -n "$imports" ] && printf '%s\n' "$imports"
            echo "just run {"
            [ -n "$defs" ] && printf '%s\n' "$defs"
            printf '%s\n' "$line"
            echo "}"
        } > "$tmp"
        if "$KCC" -r "$tmp" 2>"$err"; then
            # Remember definitions/bindings so later lines can use them.
            case "$line" in
                import\ *)               imports="${imports:+$imports$'\n'}$line" ;;
                func\ *|struct\ *|let\ *) defs="${defs:+$defs$'\n'}$line" ;;
            esac
        else
            sed 's/^/  /' "$err" >&2
        fi
        rm -f "$tmp"
    done
    rm -f "$err"
    echo "bye"
}

# No args → REPL.
if [ "$#" -eq 0 ]; then
    _repl
    exit $?
fi

# ── Script run ────────────────────────────────────────────────────────
SCRIPT="$1"

# Decide whether to auto-wrap top-level code. Skip wrapping (run as-is) when
# the file already has an explicit `just run` entry point, or declares a
# `module` (a library, not a runnable script), or isn't a readable file.
# Strip `//` line comments before checking so the words "just run" / "module"
# inside a comment don't fool the detector.
needs_wrap=0
if [ -f "$SCRIPT" ]; then
    code="$(sed 's,//.*$,,' "$SCRIPT")"
    if ! printf '%s\n' "$code" | grep -qE '(^|[^[:alnum:]_])just[[:space:]]+run([^[:alnum:]_]|$)' \
       && ! printf '%s\n' "$code" | grep -qE '^[[:space:]]*module[[:space:]]'; then
        needs_wrap=1
    fi
fi

if [ "$needs_wrap" -eq 0 ]; then
    exec "$KCC" -r "$@"
fi

# Auto-wrap: strip a leading shebang line, wrap the rest in `just run { }`.
shift  # remaining args ($@) are the script's own args
TMP="${TMPDIR:-/tmp}/kr_wrap_$$_${RANDOM}.ks"
trap 'rm -f "$TMP"' EXIT
{
    echo "just run {"
    sed '1{/^#!/d;}' "$SCRIPT"
    echo "}"
} > "$TMP"

"$KCC" -r "$TMP" "$@"
exit $?
