#!/usr/bin/env bash
# kr — run a Krypton script.
#
# Thin shebang-friendly wrapper around `kcc -r`. Lets you write:
#
#   #!/usr/bin/env kr
#   just run { kp("hi") }
#
# in a .k or .ks file, `chmod +x` it, and run it like any other script.
# (Convention: prefer .ks for run-as-script files; same compiler either way.)
#
# All args after the script are passed through to it (visible via
# `arg(0)`, `arg(1)`, ... and `argCount()`).

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# kcc.sh was removed in 0c0dc57b; the `kcc` driver owns `-r` now. Prefer a
# kcc next to this script (installed/tarball layout), else fall back to kcc
# on PATH (dev checkout, where kcc is installed via Homebrew).
KCC="$SCRIPT_DIR/kcc"
if [ ! -x "$KCC" ]; then KCC="$(command -v kcc)"; fi
if [ -z "$KCC" ]; then
    echo "kr: cannot find 'kcc' (not next to this script, not on PATH)" >&2
    exit 127
fi

exec "$KCC" -r "$@"
