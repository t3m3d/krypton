{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Krypton",
  "scopeName": "source.krypton",
  "fileTypes": ["k"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#entry-point" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.krypton",
          "match": "//.*$"
        },
        {
          "name": "comment.block.krypton",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.krypton",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.krypton",
              "match": "\\\\[nrt\\\\\"']"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.krypton",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.krypton",
          "match": "\\b(if|else|while|break|emit|return)\\b"
        },
        {
          "name": "keyword.declaration.krypton",
          "match": "\\b(func|fn|let|module)\\b"
        },
        {
          "name": "keyword.other.entry.krypton",
          "match": "\\b(just|go)\\b"
        },
        {
          "name": "keyword.other.quantum.krypton",
          "match": "\\b(quantum|qpute|process|measure|prepare)\\b"
        },
        {
          "name": "constant.language.boolean.krypton",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.krypton",
          "match": "\\b(print|len|substring|toInt|split|startsWith|readFile|arg|argCount|getLine|lineCount|count|envNew|envSet|envGet|makeResult|getResultVal|getResultPos|getResultFlag|isTruthy|sbNew|sbAppend|sbToString|tokenize|isDigit|isAlpha|isAlphaNum)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(func|fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.krypton" },
            "2": { "name": "entity.name.function.krypton" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.krypton" }
          }
        }
      ]
    },
    "entry-point": {
      "patterns": [
        {
          "match": "\\b(just|go)\\s+(run|[a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{",
          "captures": {
            "1": { "name": "keyword.other.entry.krypton" },
            "2": { "name": "entity.name.section.krypton" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.krypton",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.krypton",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.krypton",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.krypton",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.krypton",
          "match": "->"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.krypton",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.parameters.krypton",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.bracket.krypton",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.krypton",
          "match": "[,;:]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.krypton",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
