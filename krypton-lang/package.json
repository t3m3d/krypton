{
  "name": "krypton-lang",
  "displayName": "Krypton",
  "description": "Syntax highlighting for the Krypton programming language (.k files)",
  "version": "1.8.0",
  "publisher": "krypton-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/t3m3d/krypton"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "krypton",
        "aliases": ["Krypton", "krypton"],
        "extensions": [".k"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "krypton",
        "scopeName": "source.krypton",
        "path": "./syntaxes/krypton.tmLanguage.json"
      }
    ]
  }
}
