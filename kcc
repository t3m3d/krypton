#!/usr/bin/env bash
# kcc — thin dispatcher for the Krypton compiler.
#
# This forwards every invocation to kcc.sh, the single maintained driver.
# Keeping kcc a 1-line shim (rather than a full copy of the driver) is the
# original 2.0.0 design and prevents the two from drifting.
#
# History: the 2.1.1 repo shipped a stale 15.5KB copy of kcc.sh here whose
# KCC_EXE pointed at this script itself instead of the platform compiler
# binary (compiler/linux_x86/kcc-x64), so `kcc foo.k` recursed forever and
# `./install.sh` produced a non-working `kcc` command. See kcc.sh's 2.1.1
# note for the full story. This shim restores the intended split:
#   kcc     → thin dispatcher (this file)
#   kcc.sh  → full driver (--native / --llvm / --ir / -e / -r / ...)

# Resolve through symlinks so /usr/local/bin/kcc → repo/kcc finds repo files,
# then hand off to kcc.sh sitting next to us (passed by its real path so
# kcc.sh's own SCRIPT_DIR resolves to the repo root).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    SDIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$SDIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

exec "$SCRIPT_DIR/kcc.sh" "$@"
