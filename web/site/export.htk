// export.htk — static site generator for krypton-lang.org
// Generates .html files in dist/ folder. Upload to any host.
// Build: kcc export.htk > /tmp/export.c && gcc /tmp/export.c -o export.exe -w
// Run:   export.exe

import "k:htmk"
import "k:kcss"

// ── Theme colors + CSS ───────────────────────────────────────────────
// CSS authored via kcss (the Krypton CSS DSL).
// Theme custom properties and breakpoints go through kcss helpers;
// dense rule bodies stay as raw strings since CSS itself is already
// terse and wrapping every declaration would hurt readability more than
// help. Pattern: kcss for structure, raw strings for property soup.

func siteTheme() {
    emit kcssRoot(
        kcssVar("primary",      "#7722ff") +
        kcssVar("primary-dark", "#5d16da") +
        kcssVar("bg",           "#fafafa") +
        kcssVar("text",         "#222") +
        kcssVar("text-light",   "#555") +
        kcssVar("card-bg",      "#fff") +
        kcssVar("card-border",  "#e0e0e0") +
        kcssVar("code-bg",      "#1e1e2e") +
        kcssVar("code-text",    "#cdd6f4") +
        kcssVar("nav-bg",       "#0a0a0f") +
        kcssVar("nav-text",     "#eee")
    )
}

// System-following light/dark theme. When the user's OS / browser is in
// dark mode (`prefers-color-scheme: dark`), the CSS custom properties
// flip to a dark palette. No JS, no localStorage, no toggle button —
// the site just matches whatever the user already picked at the OS
// level. Light mode stays the default (siteTheme()).
//
// We also patch a handful of hardcoded light-only colors so the diff /
// table-hover / inline-code spots don't burn out against a dark bg.
func siteDarkOverrides() {
    emit "@media (prefers-color-scheme: dark){" +
        ":root{" +
            "--bg:#0f0f17;" +
            "--text:#e4e4ec;" +
            "--text-light:#9a9aaa;" +
            "--card-bg:#1a1a26;" +
            "--card-border:#2d2d40;" +
            "--primary:#8842ff;" +
            "--primary-dark:#7733ff;" +
        "}" +
        "p code{background:#262636;color:#bda6ff}" +
        "tr:hover td{background:#1d1d2c}" +
        ".dotbg,section[style*=\"background:#f4f0ff\"]{background:#15151f !important}" +
        ".card{box-shadow:0 1px 0 rgba(255,255,255,0.03)}" +
        "pre{border-color:#2d2d40}" +
    "}"
}

func siteAnims() {
    emit kcssKeyframes("gradShift",
            "0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}") +
         kcssKeyframes("fadeUp",
            "from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}") +
         kcssKeyframes("pulse",
            "0%,100%{box-shadow:0 0 0 0 rgba(119,34,255,0.3)}50%{box-shadow:0 0 0 12px rgba(119,34,255,0)}") +
         kcssKeyframes("float1",
            "0%,100%{transform:translate(0,0) rotate(0deg)}25%{transform:translate(30px,-20px) rotate(90deg)}50%{transform:translate(-10px,-40px) rotate(180deg)}75%{transform:translate(-30px,-10px) rotate(270deg)}") +
         kcssKeyframes("float2",
            "0%,100%{transform:translate(0,0) rotate(45deg)}33%{transform:translate(-40px,20px) rotate(135deg)}66%{transform:translate(20px,-30px) rotate(225deg)}") +
         kcssKeyframes("glow",
            "0%,100%{opacity:0.3}50%{opacity:0.7}") +
         kcssKeyframes("logoGlow",
            "0%,100%{text-shadow:0 0 8px rgba(119,34,255,0.6)}50%{text-shadow:0 0 20px rgba(119,34,255,1),0 0 40px rgba(119,34,255,0.4)}") +
         kcssKeyframes("typeBar",
            "0%,100%{border-color:var(--code-text)}50%{border-color:transparent}")
}

func siteCSS() {
    emit kcssStyle(
        siteTheme() +
        siteDarkOverrides() +
        siteAnims() +
        ".reveal{opacity:0;transform:translateY(30px);transition:opacity 0.6s ease,transform 0.6s ease}.reveal.visible{opacity:1;transform:translateY(0)}" +
        "*{box-sizing:border-box;margin:0;padding:0}" +
        "html{scroll-behavior:smooth}" +
        "body{font-family:'Segoe UI',system-ui,sans-serif;color:var(--text);background:var(--bg);line-height:1.6}" +
        "a{color:var(--primary);text-decoration:none;transition:color 0.2s}a:hover{color:var(--primary-dark);text-decoration:underline}" +
        "nav{background:var(--nav-bg);padding:14px 0;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px);border-bottom:1px solid rgba(119,34,255,0.15)}" +
        "nav .wrap{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 20px}" +
        "nav .logo{color:#fff;font-size:1.4rem;font-weight:700;letter-spacing:-0.5px}" +
        "nav .logo span{color:var(--primary);font-size:1.6rem;animation:logoGlow 3s ease-in-out infinite}" +
        "nav .links a{color:var(--nav-text);margin-left:24px;font-size:0.95rem;transition:color 0.2s;position:relative}" +
        "nav .links a:hover{color:var(--primary);text-decoration:none}" +
        "nav .links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--primary);transition:width 0.3s}" +
        "nav .links a:hover::after{width:100%}" +
        ".hero{background:linear-gradient(135deg,#7722ff,#5d16da,#3a0ca3,#7722ff);background-size:300% 300%;animation:gradShift 8s ease infinite;color:#fff;padding:100px 20px 80px;text-align:center;position:relative;overflow:hidden}" +
        ".hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 20% 50%,rgba(255,255,255,0.08) 0%,transparent 50%),radial-gradient(circle at 80% 50%,rgba(255,255,255,0.05) 0%,transparent 50%)}" +
        "#heroCanvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0}" +
        ".hero>*{position:relative;z-index:1}" +
        ".floater{position:fixed;pointer-events:none;z-index:0;opacity:0.04;border:2px solid var(--primary)}" +
        ".floater.f1{width:300px;height:300px;border-radius:50%;top:10%;right:-80px;animation:float1 20s ease-in-out infinite}" +
        ".floater.f2{width:200px;height:200px;top:60%;left:-60px;animation:float2 25s ease-in-out infinite}" +
        ".floater.f3{width:150px;height:150px;border-radius:50%;bottom:10%;right:10%;animation:float1 18s ease-in-out infinite reverse}" +
        ".floater.f4{width:100px;height:100px;top:30%;left:20%;animation:float2 22s ease-in-out infinite reverse}" +
        ".hero h1{font-size:3rem;margin-bottom:16px;font-weight:800;letter-spacing:-1px;animation:fadeUp 0.8s ease;position:relative}" +
        ".hero p{font-size:1.25rem;max-width:700px;margin:0 auto 32px;opacity:0.92;animation:fadeUp 0.8s ease 0.2s both;position:relative}" +
        ".hero .btn{display:inline-block;padding:14px 32px;border-radius:8px;font-weight:600;margin:0 8px;font-size:1rem;transition:transform 0.2s,box-shadow 0.2s;animation:fadeUp 0.8s ease 0.4s both;position:relative}" +
        ".hero .btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.2);text-decoration:none}" +
        ".hero .btn.primary{background:#fff;color:var(--primary-dark)}" +
        ".hero .btn.outline{background:transparent;border:2px solid rgba(255,255,255,0.7);color:#fff}" +
        ".hero .btn.outline:hover{border-color:#fff;background:rgba(255,255,255,0.1)}" +
        ".wrap{max-width:1100px;margin:0 auto;padding:20px}" +
        "section{padding:60px 20px}" +
        "section .wrap{max-width:1100px;margin:0 auto}" +
        ".dotbg{background-image:radial-gradient(circle,rgba(119,34,255,0.08) 1px,transparent 1px);background-size:24px 24px}" +
        "h2{font-size:1.9rem;margin-bottom:20px;font-weight:700;background:linear-gradient(135deg,var(--primary),var(--primary-dark),#3a0ca3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:inline-block}" +
        "h3{font-size:1.3rem;margin:20px 0 8px;color:var(--primary-dark)}" +
        ".grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-top:20px}" +
        ".card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:12px;padding:28px;transition:transform 0.25s,box-shadow 0.25s}" +
        ".card{position:relative;overflow:hidden}" +
        ".card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(119,34,255,0.12)}" +
        ".card .card-glow{position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(119,34,255,0.4),rgba(119,34,255,0.15) 40%,transparent 70%);pointer-events:none;transform:translate(-50%,-50%);opacity:0;transition:opacity 0.3s}" +
        ".card:hover .card-glow{opacity:1}" +
        "#topBtn{position:fixed;bottom:24px;right:24px;width:48px;height:48px;border-radius:50%;background:var(--primary);color:#fff;border:none;font-size:1.4rem;cursor:pointer;opacity:0;transition:opacity 0.3s,transform 0.3s;transform:translateY(20px);z-index:99;box-shadow:0 4px 16px rgba(119,34,255,0.3)}" +
        "#topBtn.show{opacity:1;transform:translateY(0)}" +
        "#topBtn:hover{background:var(--primary-dark);transform:translateY(-2px)}" +
        ".type-cursor{border-right:2px solid var(--code-text);animation:typeBar 0.8s step-end infinite;padding-right:2px}" +
        ".card h3{margin-top:0;color:var(--primary);font-size:1.2rem}" +
        "pre{background:var(--code-bg);color:var(--code-text);padding:20px;border-radius:10px;overflow-x:auto;font-size:0.9rem;line-height:1.6;border:1px solid #313244}" +
        "code{font-family:'Cascadia Code','Fira Code',Consolas,monospace}" +
        "code[contenteditable]:focus{outline:2px solid var(--primary);outline-offset:4px}" +
        "p code{background:#f0edff;padding:2px 8px;border-radius:4px;font-size:0.88em;color:var(--primary-dark)}" +
        // Hide the text caret on plain content; only show it where it's
        // actually useful (the playground / lesson code boxes that opt in
        // via contenteditable, plus real form fields). Without this, clicking
        // any text on a page paints a blinking white I-beam that looks broken.
        "body{caret-color:transparent}" +
        "[contenteditable=" + DQ() + "true" + DQ() + "],input,textarea{caret-color:var(--primary)}" +
        ".kw{color:#cba6f7}.fn{color:#89b4fa}.str{color:#a6e3a1}.cm{color:#6c7086;font-style:italic}.num{color:#fab387}" +
        ".table-wrap{overflow-x:auto}" +
        "table{border-collapse:collapse;width:100%;margin:16px 0;border-radius:8px;overflow:hidden}" +
        "th,td{border:1px solid var(--card-border);padding:12px 16px;text-align:left}" +
        "th{background:var(--primary);color:#fff;font-weight:600}" +
        "tr:hover td{background:#f8f6ff}" +
        "footer{background:var(--nav-bg);color:var(--nav-text);text-align:center;padding:32px;font-size:0.9rem;border-top:1px solid rgba(119,34,255,0.15)}" +
        "footer a{color:var(--primary)}" +
        ".tag{display:inline-block;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;padding:4px 14px;border-radius:20px;font-size:0.8rem;margin-bottom:8px;font-weight:600}" +
        ".stat{text-align:center;padding:20px}.stat .num{font-size:2.5rem;font-weight:800;color:var(--primary);display:block}.stat .label{font-size:0.95rem;color:var(--text-light)}" +
        "ul{margin:8px 0 8px 24px}li{margin:4px 0}" +
        ".nav-sponsor{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#ff5277,#d9326a);color:#fff!important;padding:6px 14px;border-radius:999px;font-weight:600;font-size:0.88rem;margin-left:18px;transition:transform 0.15s,box-shadow 0.15s;-webkit-tap-highlight-color:transparent;box-shadow:0 2px 8px rgba(217,50,106,0.35)}" +
        ".nav-sponsor:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(217,50,106,0.5);text-decoration:none}" +
        ".nav-sponsor::after{display:none!important}" +
        ".nav-ks{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#7722ff,#3a0ca3);color:#fff!important;padding:6px 14px;border-radius:999px;font-weight:600;font-size:0.88rem;margin-left:18px;transition:transform 0.15s,box-shadow 0.15s,filter 0.2s;-webkit-tap-highlight-color:transparent;box-shadow:0 2px 8px rgba(119,34,255,0.4);position:relative;overflow:hidden}" +
        ".nav-ks span{letter-spacing:0.3px}" +
        ".nav-ks:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(119,34,255,0.55);text-decoration:none;filter:brightness(1.08)}" +
        ".nav-ks::after{display:none!important}" +
        ".nav-ks::before{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent 35%,rgba(255,255,255,0.4) 50%,transparent 65%);transform:translateX(-100%);transition:transform 0.6s ease;pointer-events:none}" +
        ".nav-ks:hover::before{transform:translateX(100%)}" +
        ".tier-recommended{position:relative;border:2px solid var(--primary);box-shadow:0 8px 24px rgba(119,34,255,0.18);transform:translateY(-4px)}" +
        ".tier-recommended:hover{transform:translateY(-8px)}" +
        ".tier-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#ff5277,#d9326a);color:#fff;padding:4px 14px;border-radius:999px;font-size:0.72rem;font-weight:700;letter-spacing:0.5px;box-shadow:0 2px 8px rgba(217,50,106,0.4);white-space:nowrap}" +
        ".run-btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border:none;border-radius:8px;padding:10px 22px;font-size:0.95rem;font-weight:600;cursor:pointer;margin:14px 0 12px;box-shadow:0 4px 12px rgba(119,34,255,0.25);transition:transform 0.15s,box-shadow 0.15s,opacity 0.15s;-webkit-tap-highlight-color:transparent}" +
        ".run-btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(119,34,255,0.35)}" +
        ".run-btn:active{transform:translateY(0)}" +
        ".run-btn:disabled{opacity:0.6;cursor:wait;transform:none;box-shadow:none}" +
        ".run-out{background:#0f0f17;color:#cdd6f4;padding:16px;border-radius:10px;border:1px solid #2a2a3a;font-family:'Cascadia Code','Fira Code',Consolas,monospace;font-size:0.88rem;line-height:1.55;white-space:pre-wrap;word-break:break-word;min-height:48px;margin:0 0 18px;border-left:3px solid var(--primary)}" +
        ".run-out.ok{border-left-color:#a6e3a1}" +
        ".run-out.err{border-left-color:#f38ba8;color:#f5c2c7}" +
        ".nav-toggle{display:none;background:transparent;border:1px solid rgba(255,255,255,0.18);border-radius:8px;width:42px;height:42px;color:#fff;font-size:1.25rem;cursor:pointer;padding:0;align-items:center;justify-content:center;-webkit-tap-highlight-color:transparent;transition:border-color 0.2s,background 0.2s}" +
        ".nav-toggle:hover{border-color:rgba(255,255,255,0.45);background:rgba(255,255,255,0.04)}" +
        kcssOnTablet(
            "nav .links a{margin-left:14px;font-size:0.9rem}" +
            ".hero h1{font-size:2.4rem}" +
            ".hero{padding:80px 20px 60px}" +
            ".hero p{font-size:1.15rem}" +
            ".grid{grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}" +
            "section{padding:48px 20px}"
        ) +
        kcssOnMobile(
            "nav .wrap{flex-wrap:wrap;padding:0 14px}" +
            "nav .logo{font-size:1.2rem}" +
            "nav .logo span{font-size:1.4rem}" +
            ".nav-toggle{display:flex}" +
            "nav .links{display:none;flex-basis:100%;flex-direction:column;margin-top:10px;padding-top:6px;border-top:1px solid rgba(119,34,255,0.18)}" +
            "nav .links.open{display:flex}" +
            "nav .links a{margin:0;padding:12px 4px;font-size:1rem;border-bottom:1px solid rgba(255,255,255,0.06)}" +
            "nav .links a:last-child{border-bottom:none}" +
            "nav .links a::after{display:none}" +
            ".hero{padding:52px 18px 44px}" +
            ".hero h1{font-size:1.9rem;letter-spacing:-0.5px}" +
            ".hero p{font-size:1rem;margin-bottom:24px;padding:0 6px}" +
            ".hero .btn{display:block;margin:10px auto;max-width:260px;padding:12px 24px;-webkit-tap-highlight-color:transparent}" +
            ".hero .tag{margin-bottom:14px}" +
            "section{padding:36px 14px}" +
            ".wrap{padding:0 14px}" +
            "h2{font-size:1.5rem}h3{font-size:1.1rem}" +
            ".grid{grid-template-columns:1fr;gap:14px}" +
            ".card{padding:20px}" +
            "pre{padding:14px;font-size:0.78rem;border-radius:8px;line-height:1.55}" +
            ".stat .num{font-size:2rem}" +
            ".stat .label{font-size:0.85rem}" +
            "footer{padding:24px 14px;font-size:0.85rem}" +
            "#topBtn{width:44px;height:44px;bottom:16px;right:16px;font-size:1.2rem}" +
            ".floater.f1{width:200px;height:200px;right:-100px}" +
            ".floater.f2{width:130px;height:130px}" +
            ".floater.f3{width:110px;height:110px}" +
            ".floater.f4{display:none}" +
            "table{font-size:0.85rem}" +
            "th,td{padding:10px 12px}"
        ) +
        kcssReducedMotion(
            "*,*::before,*::after{animation-duration:0.001s!important;animation-iteration-count:1!important;transition-duration:0.001s!important}" +
            "#heroCanvas{display:none}"
        )
    )
}

func siteJS() {
    emit htScriptInline(
        "document.addEventListener('DOMContentLoaded',function(){" +
        "var navT=document.querySelector('.nav-toggle');" +
        "var navL=document.getElementById('navLinks');" +
        "if(navT&&navL){" +
            "navT.addEventListener('click',function(){" +
                "var open=navL.classList.toggle('open');" +
                "navT.setAttribute('aria-expanded',open);" +
                "navT.innerHTML=open?'\\u00d7':'\\u2630';" +
            "});" +
            "navL.querySelectorAll('a').forEach(function(a){" +
                "a.addEventListener('click',function(){" +
                    "navL.classList.remove('open');" +
                    "navT.setAttribute('aria-expanded','false');" +
                    "navT.innerHTML='\\u2630';" +
                "});" +
            "});" +
        "}" +
        "var stats=document.querySelectorAll('.stat .num');" +
        "stats.forEach(function(el){" +
        "var target=parseInt(el.getAttribute('data-n'));" +
        "var step=Math.max(1,Math.floor(target/40));" +
        "var current=0;" +
        "var timer=setInterval(function(){" +
        "current+=step;if(current>=target){current=target;clearInterval(timer)}" +
        "el.textContent=current;" +
        "},30);" +
        "});" +
        "var cards=document.querySelectorAll('.card');" +
        "cards.forEach(function(card){" +
        "var g=document.createElement('div');g.className='card-glow';card.appendChild(g);" +
        "card.addEventListener('mousemove',function(e){var r=card.getBoundingClientRect();g.style.left=(e.clientX-r.left)+'px';g.style.top=(e.clientY-r.top)+'px';});" +
        "});" +
        "var reveals=document.querySelectorAll('.card,.stat');reveals.forEach(function(el){if(el.getBoundingClientRect().top>window.innerHeight*0.5)el.classList.add('reveal');});" +
        "function checkReveal(){reveals.forEach(function(el){var t=el.getBoundingClientRect().top;if(t<window.innerHeight-60)el.classList.add('visible');});}" +
        "window.addEventListener('scroll',checkReveal);checkReveal();" +
        "var topBtn=document.getElementById('topBtn');" +
        "if(topBtn){window.addEventListener('scroll',function(){if(window.scrollY>400)topBtn.classList.add('show');else topBtn.classList.remove('show');});}" +
        "var tc=document.getElementById('typeCode');" +
        "if(tc){" +
        "var raw=`func fib(n) {\\n    if n &lt;= 1 { emit n }\\n    emit fib(n - 1) + fib(n - 2)\\n}\\n\\njust run {\\n    kp(fib(10))  // 55\\n}`;" +
        "var ci=0;" +
        "function hl(s){" +
        "s=s.replace(/\\/\\/.*/g,function(m){return '<span class=cm>'+m+'</span>';});" +
        "s=s.replace(/\\b(\\d+)\\b/g,'<span class=num>$1</span>');" +
        "s=s.replace(/\\b(func|if|emit|just|run)\\b/g,'<span class=kw>$1</span>');" +
        "s=s.replace(/\\b(fib|kp)\\b/g,'<span class=fn>$1</span>');" +
        "return s;}" +
        "function typeNext(){if(ci<=raw.length){tc.innerHTML=hl(raw.substring(0,ci));ci++;setTimeout(typeNext,25);}else{tc.innerHTML=hl(raw);tc.classList.remove('type-cursor');}}" +
        "typeNext();}" +
        "var c=document.getElementById('heroCanvas');" +
        "if(c){" +
        "var ctx=c.getContext('2d');" +
        "var w,h,pts=[];" +
        "function resize(){w=c.width=c.parentElement.offsetWidth;h=c.height=c.parentElement.offsetHeight;}" +
        "resize();window.addEventListener('resize',resize);" +
        "var isMobile=window.innerWidth<600;" +
        "var pcount=isMobile?22:60;" +
        "var pdist=isMobile?90:120;" +
        "for(var i=0;i<pcount;i++){pts.push({x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-0.5)*0.6,vy:(Math.random()-0.5)*0.6,r:Math.random()*2+1});}" +
        "function draw(){" +
        "ctx.clearRect(0,0,w,h);" +
        "for(var i=0;i<pts.length;i++){" +
        "var p=pts[i];" +
        "p.x+=p.vx;p.y+=p.vy;" +
        "if(p.x<0)p.x=w;if(p.x>w)p.x=0;" +
        "if(p.y<0)p.y=h;if(p.y>h)p.y=0;" +
        "ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);" +
        "ctx.fillStyle='rgba(255,255,255,0.5)';ctx.fill();" +
        "for(var j=i+1;j<pts.length;j++){" +
        "var q=pts[j];var dx=p.x-q.x;var dy=p.y-q.y;var d=Math.sqrt(dx*dx+dy*dy);" +
        "if(d<pdist){ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);" +
        "ctx.strokeStyle='rgba(255,255,255,'+(0.15*(1-d/pdist))+')';ctx.stroke();}" +
        "}}" +
        "requestAnimationFrame(draw);}" +
        "draw();}" +
        "});"
    ) +
    // wasm_runner.js: the KryptScript runtime. Auto-detects <canvas id=
    // "heroCanvas"> and animates it via particles.wasm (compiled from
    // /particles.ks). Also wraps window.runK for lesson playback. Sourcing
    // unconditionally is fine — the script no-ops when neither condition
    // applies. v=2 busts the browser cache after the 2.2 ABI change.
    "<script src=" + DQ() + "/wasm_runner.js?v=5" + DQ() + "></script>"
}

func NL() { emit fromCharCode(10) }
func DQ() { emit fromCharCode(34) }
func DASH() { emit "&mdash;" }
func DOT() { emit "&middot;" }

func siteNav(active) {
    emit "<nav><div class=" + DQ() + "wrap" + DQ() + ">" +
         "<a href=" + DQ() + "/" + DQ() + " class=" + DQ() + "logo" + DQ() + "><span>K</span>rypton</a>" +
         "<button class=" + DQ() + "nav-toggle" + DQ() +
             " aria-label=" + DQ() + "Toggle menu" + DQ() +
             " aria-controls=" + DQ() + "navLinks" + DQ() +
             " aria-expanded=" + DQ() + "false" + DQ() + ">" +
             "&#9776;</button>" +
         "<div class=" + DQ() + "links" + DQ() + " id=" + DQ() + "navLinks" + DQ() + ">" +
         htA("/", "Home") +
         htA("/about.html", "About") +
         htA("/features.html", "Features") +
         htA("/compare.html", "Compare") +
         htA("/learn.html", "Learn") +
         htA("/playground.html", "Playground") +
         htA("/blog.html", "Blog") +
         htA("/docs.html", "Docs") +
         htA("/programs.html", "Programs") +
         htA("/kcode.html", "kcode") +
         htA("/downloads.html", "Downloads") +
         htA("/contact.html", "Contact") +
         "<a href=" + DQ() + "/kryptscript.html" + DQ() +
             " class=" + DQ() + "nav-ks" + DQ() +
             " title=" + DQ() + "KryptScript (.ks) " + DASH() + " runnable Krypton scripts" + DQ() + ">" +
             "&#10024; <span>KryptScript</span></a>" +
         "<a href=" + DQ() + "/sponsor.html" + DQ() +
             " class=" + DQ() + "nav-sponsor" + DQ() + ">&#10084; Sponsor</a>" +
         "</div></div></nav>"
}

func siteFooter() {
    emit "<footer>" +
         "<p style=" + DQ() + "margin-bottom:8px" + DQ() + ">" +
         "Built and maintained by Brian. Support the project on " +
         htA("/sponsor.html", "&#10084; GitHub Sponsors") +
         " " + DASH() + " keeps Krypton shipping." +
         "</p>" +
         "Powered by <a href=" + DQ() + "https://www.kryptonbytes.com" + DQ() + ">KryptonBytes</a> | " +
         "<a href=" + DQ() + "https://github.com/t3m3d/krypton" + DQ() + ">View on GitHub</a> | " +
         htA("/sponsor.html", "Sponsor") +
         " | All rights reserved.</footer>" +
         "<button id=" + DQ() + "topBtn" + DQ() + " onclick=" + DQ() + "window.scrollTo({top:0,behavior:'smooth'})" + DQ() + ">&uarr;</button>"
}

func floaters() {
    emit "<div class=" + DQ() + "floater f1" + DQ() + "></div>" +
         "<div class=" + DQ() + "floater f2" + DQ() + "></div>" +
         "<div class=" + DQ() + "floater f3" + DQ() + "></div>" +
         "<div class=" + DQ() + "floater f4" + DQ() + "></div>"
}

// Default OG/Twitter description used on every page. Overridable later
// by adding a per-page metaDesc(title) lookup if SEO copy varies.
func siteDesc() {
    emit "Krypton is a self-hosted programming language with native ELF, PE, and Mach-O backends. No LLVM, no GCC. Includes a full web framework (htmk, kcss, ks) and a self-hosted compiler."
}

func sitePage(title, content) {
    let fullTitle = "Krypton - " + title
    emit "<!-- Built with Krypton | krypton-lang.org -->" + fromCharCode(10) +
        htPage(fullTitle,
        siteCSS() + htMetaViewport() +
        htVoid("meta", htAttr("name", "description") + htAttr("content", siteDesc())) +
        htVoid("meta", htAttr("name", "theme-color") + htAttr("content", "#5d16da")) +
        htVoid("meta", htAttr("name", "apple-mobile-web-app-capable") + htAttr("content", "yes")) +
        htVoid("meta", htAttr("name", "apple-mobile-web-app-status-bar-style") + htAttr("content", "black-translucent")) +
        htVoid("meta", htAttr("name", "generator") + htAttr("content", "Krypton 2.1.1")) +
        htVoid("meta", htAttr("name", "author") + htAttr("content", "KryptonBytes")) +
        // Open Graph (Facebook, LinkedIn, Slack, Discord previews).
        htVoid("meta", htAttr("property", "og:title")       + htAttr("content", fullTitle)) +
        htVoid("meta", htAttr("property", "og:description") + htAttr("content", siteDesc())) +
        htVoid("meta", htAttr("property", "og:type")        + htAttr("content", "website")) +
        htVoid("meta", htAttr("property", "og:site_name")   + htAttr("content", "Krypton")) +
        htVoid("meta", htAttr("property", "og:image")       + htAttr("content", "https://krypton-lang.org/og.svg")) +
        htVoid("meta", htAttr("property", "og:url")         + htAttr("content", "https://krypton-lang.org/")) +
        // Twitter / X cards.
        htVoid("meta", htAttr("name", "twitter:card")        + htAttr("content", "summary_large_image")) +
        htVoid("meta", htAttr("name", "twitter:title")       + htAttr("content", fullTitle)) +
        htVoid("meta", htAttr("name", "twitter:description") + htAttr("content", siteDesc())) +
        htVoid("meta", htAttr("name", "twitter:image")       + htAttr("content", "https://krypton-lang.org/og.svg")) +
        // PWA + iOS home screen icon.
        htVoid("link", htAttr("rel", "manifest") + htAttr("href", "/manifest.json")) +
        htVoid("link", htAttr("rel", "icon") + htAttr("type", "image/svg+xml") + htAttr("href", "/icon.svg")) +
        htVoid("link", htAttr("rel", "apple-touch-icon") + htAttr("href", "/icon.svg")) +
        htVoid("link", htAttr("rel", "alternate") + htAttr("type", "application/atom+xml") + htAttr("title", "Krypton Dev Log") + htAttr("href", "/atom.xml")),
        floaters() + siteNav(title) + content + siteFooter() + siteJS()
    )
}

func hlKw(s) { emit "<span class=" + DQ() + "kw" + DQ() + ">" + s + "</span>" }
func hlFn(s) { emit "<span class=" + DQ() + "fn" + DQ() + ">" + s + "</span>" }
func hlStr(s) { emit "<span class=" + DQ() + "str" + DQ() + ">" + s + "</span>" }
func hlCm(s) { emit "<span class=" + DQ() + "cm" + DQ() + ">" + s + "</span>" }
func hlNum(s) { emit "<span class=" + DQ() + "num" + DQ() + ">" + s + "</span>" }

func statCard(num, label) {
    emit "<div class=" + DQ() + "card stat" + DQ() + "><span class=" + DQ() + "num" + DQ() + " data-n=" + DQ() + num + DQ() + ">0</span><span class=" + DQ() + "label" + DQ() + ">" + label + "</span></div>"
}

