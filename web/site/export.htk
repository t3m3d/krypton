func buildSitemap() {
    let head = "<?xml version=" + DQ() + "1.0" + DQ() + " encoding=" + DQ() + "UTF-8" + DQ() + "?>" + NL() +
               "<urlset xmlns=" + DQ() + "http://www.sitemaps.org/schemas/sitemap/0.9" + DQ() + ">" + NL()
    let topPages =
        _sitemapUrl("/") +
        _sitemapUrl("/about.html") +
        _sitemapUrl("/features.html") +
        _sitemapUrl("/learn.html") +
        _sitemapUrl("/playground.html") +
        _sitemapUrl("/blog.html") +
        _sitemapUrl("/programs.html") +
        _sitemapUrl("/kcode.html") +
        _sitemapUrl("/downloads.html") +
        _sitemapUrl("/kryptscript.html") +
        _sitemapUrl("/contact.html") +
        _sitemapUrl("/sponsor.html")
    let lessons = htEach(lessonFiles(), funcptr(_sitemapLesson))
    let posts = htEach(blogPosts(), funcptr(_sitemapPost))
    let tail = "</urlset>" + NL()
    emit head + topPages + lessons + posts + tail
}

