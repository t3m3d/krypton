}

func pageBlogPost(line) {
    let slug = _postSlug(line)
    let date = _postDate(line)
    let title = _postTitle(line)
    let path = _postPath(line)
    let src = readFile(path)
    let bodyHtml = mdToHtml(src)

    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">" + date + "</span>" +
        htH1(title) +
        htP("Dev log " + DASH() + " " + htA("/blog.html", "back to all posts")) +
        "</div>"

    let body = "<section><div class=" + DQ() + "wrap" + DQ() + " style=" + DQ() + "max-width:780px" + DQ() + ">" +
        bodyHtml +
        htP(htEm(htA("/blog.html", "&larr; All posts"))) +
        "</div></section>"

    emit sitePage(title, hero + body)
}

