// ── Playground page ──────────────────────────────────────────────────
// Standalone editor + Run button. No lesson context; visitor can write
// arbitrary Krypton in the subset the runner supports.

func pagePlayground() {
    let starterCode =
        "// Welcome to the Krypton playground." + NL() +
        "// Edit the code below and hit Run." + NL() +
        "" + NL() +
        "func fib(n) {" + NL() +
        "    if n <= 1 { emit n }" + NL() +
        "    emit fib(n - 1) + fib(n - 2)" + NL() +
        "}" + NL() +
        "" + NL() +
        "just run {" + NL() +
        "    let i = 0" + NL() +
        "    while i < 10 {" + NL() +
        "        kp(\"fib(\" + i + \") = \" + fib(i))" + NL() +
        "        i = i + 1" + NL() +
        "    }" + NL() +
        "}" + NL()

    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">Live in your browser</span>" +
        htH1("Krypton Playground") +
        htP("Write Krypton, hit Run, see output " + DASH() +
            " no install, no signup. The full lang subset that runs in-browser today.") +
        "</div>"

    let body = "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        htP(htEm("Tip: edit the code below. Drop in your own functions, try the stdlib helpers (kp, len, listNew, mapNew, htmk, kcss). Lessons covering match/struct/try, file I/O, HTTP, JSON need the real local kcc " + DASH() + " try " + htCode("kcc -r yourfile.k") + ".")) +
        "<pre><code class=" + DQ() + "k" + DQ() +
            " contenteditable=" + DQ() + "true" + DQ() +
            " spellcheck=" + DQ() + "false" + DQ() + ">" + hlCode(starterCode) + "</code></pre>" +
        "<button class=" + DQ() + "run-btn" + DQ() +
            " onclick=" + DQ() + "runK(this)" + DQ() + ">&#9654; Run</button>" +
        "<pre class=" + DQ() + "run-out" + DQ() + ">Click &#9654; Run to execute.</pre>" +
        htP("Want guided lessons instead? Start at " + htA("/learn.html", "Learn Krypton") + ".") +
        "</div></section>" +
        "<script src=" + DQ() + "/runner.js?v=5" + DQ() + "></script>"

    emit sitePage("Playground", hero + body)
}

// ── Blog ─────────────────────────────────────────────────────────────
// Minimal markdown subset → HTML. Handles headers (# / ## / ###),
// fenced code blocks (```), paragraphs (blank-line separated), inline
// code (`x`), bold (**x**), and links ([t](u)). No image, list, blockquote,
// or table support yet — add when first post needs it.

func _mdEscape(s) {
    let out = sbNew()
    let i = 0
    while i < len(s) {
        let c = s[i]
        if c == "<" { out = sbAppend(out, "&lt;") }
        else if c == ">" { out = sbAppend(out, "&gt;") }
        else if c == "&" { out = sbAppend(out, "&amp;") }
        else { out = sbAppend(out, c) }
        i += 1
    }
    emit sbToString(out)
}

// Inline pass: backtick code, bold, links. Plain text otherwise.
func _mdInline(s) {
    let out = sbNew()
    let i = 0
    let n = len(s)
    while i < n {
        let c = s[i]
        if c == "`" {
            let j = i + 1
            let buf = sbNew()
            while j < n && s[j] != "`" {
                buf = sbAppend(buf, s[j])
                j += 1
            }
            out = sbAppend(out, "<code>" + _mdEscape(sbToString(buf)) + "</code>")
            i = j + 1
        } else if c == "*" && i + 1 < n && s[i + 1] == "*" {
            let j = i + 2
            let buf = sbNew()
            while j + 1 < n && !(s[j] == "*" && s[j + 1] == "*") {
                buf = sbAppend(buf, s[j])
                j += 1
            }
            out = sbAppend(out, "<strong>" + sbToString(buf) + "</strong>")
            i = j + 2
        } else if c == "[" {
            let j = i + 1
            let txt = sbNew()
            while j < n && s[j] != "]" { txt = sbAppend(txt, s[j]); j += 1 }
            if j < n && j + 1 < n && s[j + 1] == "(" {
                let k = j + 2
                let url = sbNew()
                while k < n && s[k] != ")" { url = sbAppend(url, s[k]); k += 1 }
                out = sbAppend(out, "<a href=" + DQ() + sbToString(url) + DQ() + ">" + sbToString(txt) + "</a>")
                i = k + 1
            } else {
                out = sbAppend(out, c)
                i += 1
            }
        } else if c == "<" {
            out = sbAppend(out, "&lt;"); i += 1
        } else if c == ">" {
            out = sbAppend(out, "&gt;"); i += 1
        } else {
            out = sbAppend(out, c)
            i += 1
        }
    }
    emit sbToString(out)
}

func mdToHtml(src) {
    let out = sbNew()
    let n = lineCount(src)
    let i = 0
    let inCode = 0
    let inPara = 0
    let codeBuf = sbNew()
    let paraBuf = sbNew()
    while i < n {
        let line = getLine(src, i)
        if inCode == 1 {
            if len(line) >= 3 && substring(line, 0, 3) == "```" {
                out = sbAppend(out, "<pre><code>" + sbToString(codeBuf) + "</code></pre>")
                codeBuf = sbNew()
                inCode = 0
            } else {
                codeBuf = sbAppend(codeBuf, _mdEscape(line) + fromCharCode(10))
            }
            i += 1
        } else if len(line) >= 3 && substring(line, 0, 3) == "```" {
            if inPara == 1 {
                out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>")
                paraBuf = sbNew()
                inPara = 0
            }
            inCode = 1
            i += 1
        } else if len(line) >= 4 && substring(line, 0, 4) == "### " {
            if inPara == 1 { out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>"); paraBuf = sbNew(); inPara = 0 }
            out = sbAppend(out, htH3(_mdInline(substring(line, 4, len(line)))))
            i += 1
        } else if len(line) >= 3 && substring(line, 0, 3) == "## " {
            if inPara == 1 { out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>"); paraBuf = sbNew(); inPara = 0 }
            out = sbAppend(out, htH2(_mdInline(substring(line, 3, len(line)))))
            i += 1
        } else if len(line) >= 2 && substring(line, 0, 2) == "# " {
            if inPara == 1 { out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>"); paraBuf = sbNew(); inPara = 0 }
            out = sbAppend(out, htH1(_mdInline(substring(line, 2, len(line)))))
            i += 1
        } else if len(line) == 0 {
            if inPara == 1 {
                out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>")
                paraBuf = sbNew()
                inPara = 0
            }
            i += 1
        } else if len(line) >= 4 && substring(line, 0, 4) == "--- " {
            if inPara == 1 { out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>"); paraBuf = sbNew(); inPara = 0 }
            out = sbAppend(out, "<hr>")
            i += 1
        } else if len(line) == 3 && line == "---" {
            if inPara == 1 { out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>"); paraBuf = sbNew(); inPara = 0 }
            out = sbAppend(out, "<hr>")
            i += 1
        } else {
            if inPara == 1 {
                paraBuf = sbAppend(paraBuf, " " + line)
            } else {
                paraBuf = sbAppend(paraBuf, line)
                inPara = 1
            }
            i += 1
        }
    }
    if inPara == 1 {
        out = sbAppend(out, "<p>" + _mdInline(sbToString(paraBuf)) + "</p>")
    }
    if inCode == 1 {
        out = sbAppend(out, "<pre><code>" + sbToString(codeBuf) + "</code></pre>")
    }
    emit sbToString(out)
}

// Blog post registry. Add new posts here (slug, date, title, md path).
// Newest first.
func blogPosts() {
    emit "2026-06-01-elf-from-scratch|2026-06-01|Linux x86_64: writing your own ELF (no linker, no libc)|../../docs/blog/2026-06-01-elf-from-scratch.md" + NL() +
         "2026-05-30-launch-week|2026-05-30|Launch week: kcss, the lesson runner, and a 95-byte WASM proof|../../docs/blog/2026-05-30-launch-week.md"
}

func _splitPipe(line, idx) {
    let parts = sbNew()
    let count = 0
    let i = 0
    let n = len(line)
    let buf = sbNew()
    while i < n {
        if line[i] == "|" {
            if count == idx { emit sbToString(buf) }
            buf = sbNew()
            count += 1
        } else {
            buf = sbAppend(buf, line[i])
        }
        i += 1
    }
    if count == idx { emit sbToString(buf) }
    emit ""
}

func _postSlug(line)  { emit _splitPipe(line, 0) }
func _postDate(line)  { emit _splitPipe(line, 1) }
func _postTitle(line) { emit _splitPipe(line, 2) }
func _postPath(line)  { emit _splitPipe(line, 3) }

func _blogIndexCard(line) {
    let slug = _postSlug(line)
    let date = _postDate(line)
    let title = _postTitle(line)
    emit "<a class=" + DQ() + "card" + DQ() + " href=" + DQ() + "/blog/" + slug + ".html" + DQ() + ">" +
         "<span class=" + DQ() + "tag" + DQ() + ">" + date + "</span>" +
         htH3(title) +
         "</a>"
}

func pageBlog() {
    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">Dev log</span>" +
        htH1("Krypton Blog") +
