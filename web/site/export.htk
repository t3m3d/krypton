        "</div>"

    let body = "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        "<div class=" + DQ() + "grid" + DQ() + ">" +
        htEach(blogPosts(), funcptr(_blogIndexCard)) +
        "</div>" +
