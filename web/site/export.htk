    emit "<?xml version=" + DQ() + "1.0" + DQ() + " encoding=" + DQ() + "utf-8" + DQ() + "?>" + NL() +
         "<feed xmlns=" + DQ() + "http://www.w3.org/2005/Atom" + DQ() + ">" + NL() +
