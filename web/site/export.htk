         "  <updated>" + latestDate + "T00:00:00Z</updated>" + NL() +
         "  <id>https://krypton-lang.org/atom.xml</id>" + NL() +
         "  <author><name>Brian</name><email>brian@krypton-lang.org</email></author>" + NL() +
         htEach(posts, funcptr(_feedEntry)) +
         "</feed>" + NL()
}

