// ── Learn / Tutorials ────────────────────────────────────────────────

func _esc(c) {
    if c == "&" { emit "&amp;" }
    if c == "<" { emit "&lt;" }
    if c == ">" { emit "&gt;" }
    emit c
}

func _isKw(w) {
    let kws = ",func,fn,let,if,else,while,for,in,emit,return,just,run,go,match,try,catch,throw,struct,import,module,break,continue,do,true,false,and,or,not,"
    if indexOf(kws, "," + w + ",") >= 0 { emit "1" }
    emit "0"
}

// Server-side Krypton syntax highlighter. Escapes HTML and wraps
// comments / strings / numbers / keywords in the .cm/.str/.num/.kw spans
// already defined in siteCSS(). No client JS, no regex — a single char walk.
func hlCode(src) {
    let out = sbNew()
    let i = 0
    let n = len(src)
    while i < n {
        let c = src[i]
        if c == "/" && i + 1 < n && src[i + 1] == "/" {
            let cm = sbNew()
            let j = i
            while j < n && src[j] != fromCharCode(10) {
                cm = sbAppend(cm, _esc(src[j]))
                j += 1
            }
            out = sbAppend(out, "<span class=" + DQ() + "cm" + DQ() + ">" + sbToString(cm) + "</span>")
            i = j
        } else if c == DQ() {
            let st = sbNew()
            st = sbAppend(st, "&quot;")
            let j = i + 1
            while j < n && src[j] != DQ() {
                if src[j] == fromCharCode(92) && j + 1 < n {
                    st = sbAppend(st, _esc(src[j]))
                    st = sbAppend(st, _esc(src[j + 1]))
                    j += 2
                } else {
                    st = sbAppend(st, _esc(src[j]))
                    j += 1
                }
            }
            if j < n { st = sbAppend(st, "&quot;"); j += 1 }
            out = sbAppend(out, "<span class=" + DQ() + "str" + DQ() + ">" + sbToString(st) + "</span>")
            i = j
        } else if isDigit(c) {
            let num = sbNew()
            let j = i
            while j < n && isDigit(src[j]) { num = sbAppend(num, src[j]); j += 1 }
            out = sbAppend(out, "<span class=" + DQ() + "num" + DQ() + ">" + sbToString(num) + "</span>")
            i = j
        } else if isAlpha(c) || c == "_" {
            let id = sbNew()
            let j = i
            while j < n && (isAlpha(src[j]) || isDigit(src[j]) || src[j] == "_") {
                id = sbAppend(id, src[j])
                j += 1
            }
            let word = sbToString(id)
            if _isKw(word) == "1" {
                out = sbAppend(out, "<span class=" + DQ() + "kw" + DQ() + ">" + word + "</span>")
            } else {
                out = sbAppend(out, word)
            }
            i = j
        } else {
            out = sbAppend(out, _esc(c))
            i += 1
        }
    }
    emit sbToString(out)
}

// Ordered core-track lesson filenames (without .k).
func lessonFiles() {
    emit "01_hello_world" + NL() + "02_variables" + NL() + "03_strings" + NL() +
         "04_arithmetic" + NL() + "05_conditionals" + NL() + "06_while_loops" + NL() +
         "07_functions" + NL() + "08_print" + NL() + "09_to_int" + NL() +
         "10_booleans" + NL() + "11_lists" + NL() + "12_string_builder" + NL() +
         "13_pairs" + NL() + "14_file_io" + NL() + "15_arguments" + NL() +
         "16_environment" + NL() + "17_go_blocks" + NL() + "18_lines" + NL() +
         "19_pattern_matching" + NL() + "20_putting_it_together" + NL() +
         "21_structs" + NL() + "22_try_catch" + NL() + "23_for_in" + NL() +
         "24_string_interpolation" + NL() + "25_match" + NL() + "26_booleans" + NL() +
         "27_imports" + NL() + "28_maps" + NL() + "29_closures" + NL() +
         "30_json" + NL() + "31_http_client" + NL() +
         "32_html_with_htmk" + NL() + "33_styling_with_kcss" + NL() +
         "34_browser_hn"
}

func _lessonSrc(file) {
    emit readFile("../../tutorial/" + file + ".k")
}

func _lessonTitle(src) {
    let first = getLine(src, 0)
    let pos = indexOf(first, ": ")
    if pos < 0 { emit "Lesson" }
    emit substring(first, pos + 2, len(first))
}

func _lessonNum(file) {
    emit substring(file, 0, 2)
}

// _lessonCard: build one lesson card for the Learn index grid.
// Used by pageLearnIndex via htEach over the lessonFiles() list.
func _lessonCard(file) {
    let title = _lessonTitle(_lessonSrc(file))
    emit "<a class=" + DQ() + "card" + DQ() + " href=" + DQ() + "/learn/" + file + ".html" + DQ() + ">" +
         "<span class=" + DQ() + "tag" + DQ() + ">Lesson " + _lessonNum(file) + "</span>" +
         htH3(title) +
         "</a>"
}

func pageLearnIndex() {
    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        htH1("Learn Krypton") +
        htP("A hands-on tour of the language, one short lesson at a time " + DASH() +
            " from " + DQ() + "Hello, World" + DQ() + " to JSON and HTTP.") +
        "</div>"

    let files = lessonFiles()
    let cnt = lineCount(files)
    let cards = htEach(files, funcptr(_lessonCard))

    let body = "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        htH2("Core Language Track") +
        htP("" + cnt + " lessons. Each is a complete, runnable program.") +
        "<div class=" + DQ() + "grid" + DQ() + ">" + cards + "</div>" +
        "</div></section>"

    emit sitePage("Learn", hero + body)
}

// Intro paragraph = the contiguous comment lines right after the title
// line (the lesson's own one-line description), stripped of "// ".
func _lessonIntro(src) {
    let out = ""
    let n = lineCount(src)
    let i = 1
    let stop = 0
    while i < n && stop == 0 {
        let line = getLine(src, i)
        if startsWith(line, "//") {
            let t = trim(substring(line, 2, len(line)))
            if len(t) > 0 {
                if len(out) > 0 { out = out + " " }
                out = out + t
            }
            i += 1
        } else {
            stop = 1
        }
    }
    emit out
}

func pageLesson(file, prevFile, nextFile) {
    let src = _lessonSrc(file)
    let title = _lessonTitle(src)
    let intro = _lessonIntro(src)
    let outRaw = readFile("lesson_out/" + file + ".txt")

    let nav = sbNew()
    nav = sbAppend(nav, htA("/learn.html", "&larr; All lessons"))
    if len(prevFile) > 0 {
        nav = sbAppend(nav, " &nbsp; " + htA("/learn/" + prevFile + ".html", "Prev"))
    }
    if len(nextFile) > 0 {
        nav = sbAppend(nav, " &nbsp; " + htA("/learn/" + nextFile + ".html", "Next &rarr;"))
    }
    let navStr = sbToString(nav)

    let introBlock = ""
    if len(intro) > 0 { introBlock = htP(intro) }

    let outputBlock = ""
    if len(outRaw) > 0 {
        outputBlock = htH3("Output") +
            "<pre><code>" + htEscape(outRaw) + "</code></pre>"
    }

    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">Lesson " + _lessonNum(file) + "</span>" +
        htH1(title) +
        introBlock +
        "</div>"

    let body = hero +
        "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        htP(navStr) +
        "<pre><code class=" + DQ() + "k" + DQ() +
            " contenteditable=" + DQ() + "true" + DQ() +
            " spellcheck=" + DQ() + "false" + DQ() + ">" + hlCode(src) + "</code></pre>" +
        "<button class=" + DQ() + "run-btn" + DQ() +
            " onclick=" + DQ() + "runK(this)" + DQ() + ">&#9654; Run</button>" +
        "<pre class=" + DQ() + "run-out" + DQ() + ">Click &#9654; Run to execute. " +
            "Lessons using k:fs/k:http/match/struct need the real runtime.</pre>" +
        htP(htEm("Tip: this code box is editable " + DASH() +
            " tweak it, then hit Run, or copy into a .k file and run locally.")) +
        outputBlock +
        htP("Run it locally: " + htCode("kcc -r tutorial/" + file + ".k")) +
        htP(navStr) +
        "</div></section>" +
        "<script src=" + DQ() + "/runner.js?v=5" + DQ() + "></script>" +
        "<script src=" + DQ() + "/wasm_runner.js?v=1" + DQ() + "></script>"

    emit sitePage(title, body)
}

// ── Static export (writes .html files) ───────────────────────────────

func writePage(path, html) {
    writeFile(path, html)
    printErr("wrote " + path)
}

just run {
    let dist = "dist"

    writePage(dist + "/index.html", pageHome())
    writePage(dist + "/about.html", pageAbout())
    writePage(dist + "/features.html", pageFeatures())
    writePage(dist + "/compare.html", pageCompare())
    writePage(dist + "/programs.html", pagePrograms())
    writePage(dist + "/downloads.html", pageDownloads())
    writePage(dist + "/kryptscript.html", pageKryptScript())
    writePage(dist + "/contact.html", pageContact())
    writePage(dist + "/kcode.html", pageKcode())
    writePage(dist + "/sponsor.html", pageSponsor())
    writePage(dist + "/playground.html", pagePlayground())
    writePage(dist + "/blog.html", pageBlog())
    shellRun("mkdir dist" + fromCharCode(47) + "blog")
    let posts = blogPosts()
    let postCnt = lineCount(posts)
    let pi = 0
    while pi < postCnt {
        let post = getLine(posts, pi)
        if len(post) > 0 {
            writePage(dist + "/blog/" + _postSlug(post) + ".html", pageBlogPost(post))
        }
        pi += 1
    }
    writePage(dist + "/sitemap.xml", buildSitemap())
    writePage(dist + "/robots.txt", buildRobots())
    writePage(dist + "/atom.xml", buildAtomFeed())

    writePage(dist + "/docs.html", pageDocsIndex())
    shellRun("mkdir dist" + fromCharCode(47) + "docs")
    let docs = siteDocs()
    let docsCnt = lineCount(docs)
    let di = 0
    while di < docsCnt {
        let doc = getLine(docs, di)
        if len(doc) > 0 {
            writePage(dist + "/docs/" + _splitPipe(doc, 0) + ".html", pageDocsPost(doc))
        }
        di += 1
    }

    // Learn section: index + one page per tutorial lesson.
    // mkdir -p style: cmd.exe on Windows (backslash path), POSIX mkdir -p
    // elsewhere. Both no-op harmlessly if the dir already exists.
    if environ("OS") == "Windows_NT" {
        shellRun("mkdir dist" + fromCharCode(92) + "learn")
    } else {
        shellRun("mkdir -p dist/learn")
    }
    writePage(dist + "/learn.html", pageLearnIndex())
    let files = lessonFiles()
    let cnt = lineCount(files)
    let i = 0
    let wasmOk = 0
    let wasmSkip = 0
    while i < cnt {
        let file = getLine(files, i)
        if len(file) > 0 {
            let prevFile = ""
            let nextFile = ""
            if i > 0 { prevFile = getLine(files, i - 1) }
            if i + 1 < cnt { nextFile = getLine(files, i + 1) }
            writePage(dist + "/learn/" + file + ".html", pageLesson(file, prevFile, nextFile))

            // Precompile lesson to .wasm so wasm_runner.js can serve a real
            // Krypton-emitted module when the code box is unedited. Failures
            // are silent: a missing .wasm just falls back to runner.js's
            // JS bridge (matches the contract in WASM_PHASE_1_SPLIT.md §B.4).
            //
            // WINDOWS-ONLY: this shells out to kcc.exe / wasm_self.exe with
            // backslash paths + cmd builtins (del, 2>nul). On macOS / Linux
            // (environ("OS") != "Windows_NT") we skip it and reuse the .wasm
            // files already committed under dist/learn/ from the Windows build.
            if environ("OS") == "Windows_NT" {
                let srcK = "..\\..\\tutorial\\" + file + ".k"
                let kir  = "dist\\learn\\" + file + ".kir"
                let wsm  = "dist\\learn\\" + file + ".wasm"
                shellRun("kcc.exe --ir " + srcK + " > " + kir + " 2>nul")
                shellRun("..\\..\\compiler\\wasm32\\wasm_self.exe " + kir + " " + wsm + " >nul 2>nul")
                shellRun("del " + kir + " >nul 2>nul")
                wasmOk += 1
            } else {
                wasmSkip += 1
            }
        }
        i += 1
    }

    printErr("done: 6 pages + learn index + " + cnt + " lessons in " + dist + "/  (.wasm: " + wasmOk + " emitted, " + wasmSkip + " skipped)")
}
