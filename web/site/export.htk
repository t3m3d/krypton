        htP("Real software written in Krypton.") +
        "</div>"
    let content = hero +
        "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        "<div class=" + DQ() + "card" + DQ() + " style=" + DQ() + "margin:24px 0" + DQ() + ">" +
        "<span class=" + DQ() + "tag" + DQ() + ">Featured</span>" +
        htH2("kryofetch") +
        htP("A system-information fetch tool. Reads user, OS, CPU, RAM/disk with bar graphs, GPU, shell, terminal, resolution, uptime, and theme " + DASH() + " rendered next to a coloured ASCII logo.") +
        htP("Windows port (~600 lines, 7 modules) talks to Win32 directly " + DASH() + " registry, GlobalMemoryStatusEx, DXGI. Linux port reads /proc, /sys, /etc/os-release via native readProc syscalls. No WMI, no PowerShell, no Python.") +
        htP(htA("https://github.com/t3m3d/kryofetch", "View on GitHub")) +
        htP(htEm("Windows 10/11 (native PE/COFF) " + DOT() + " Linux x86_64 (static syscall-only ELF, no gcc at runtime). aarch64 follows when its Milestone 4 ships string-concat.")) +
        "</div>" +
        "<div class=" + DQ() + "card" + DQ() + " style=" + DQ() + "margin:24px 0" + DQ() + ">" +
        "<span class=" + DQ() + "tag" + DQ() + ">New</span>" +
        htH2("kmon") +
        htP("Real-time network monitor. Captures live packets, parses Ethernet + IPv4 + TCP/UDP/ICMP in pure Krypton, streams to a browser dashboard via SSE.") +
        htP(htA("https://github.com/t3m3d/kmon", "View on GitHub")) +
        htP(htEm("Windows 10/11 " + DOT() + " requires Npcap")) +
        "</div>" +
        "<div class=" + DQ() + "card" + DQ() + " style=" + DQ() + "margin:24px 0" + DQ() + ">" +
        "<span class=" + DQ() + "tag" + DQ() + ">New</span>" +
        htH2("yubiKrypt") +
        htP("A YubiKey detector and OATH/TOTP authenticator written entirely in KryptScript. Detects a plugged-in key, shows model + interfaces, and (with ykman installed) renders live TOTP codes with a 30-second countdown.") +
        htP("Single self-contained .ks file. macOS frontend reused verbatim on Linux " + DASH() + " same .ks, same builtins, just a different native backend underneath.") +
        htP(htA("https://github.com/t3m3d/yubikrypt", "View on GitHub")) +
        htP(htEm("macOS arm64 " + DOT() + " Linux x86_64 " + DOT() + " no C, no clang. (Linux aarch64 follows when that backend reaches string-concat support.)")) +
        "</div>" +
        "<div class=" + DQ() + "card" + DQ() + " style=" + DQ() + "margin:24px 0" + DQ() + ">" +
        "<span class=" + DQ() + "tag" + DQ() + ">New</span>" +
        htH2("kryoterm") +
        htP("A terminal emulator being built in pure Krypton plus KryptScript " + DASH() + " no Qt, no GTK, no libX11. The window comes from stdlib/x11.k (the Krypton X11 wire-protocol client speaking directly over a socket); the binary is a static syscall-only ELF.") +
        htP("Phase 0 shipped: spawns a child process via shellRun and echoes its output. Phase 1 (X11 window) and Phase 2 (in-window rendering) follow as stdlib/x11.k gains CreateWindow + ImageText8. Sibling project to terk (Qt6/C++) " + DASH() + " kryoterm exists to retire that C++ surface once feature parity lands.") +
        htP(htA("https://github.com/t3m3d/kryoterm", "View on GitHub")) +
        htP(htEm("Linux x86_64 " + DOT() + " 4126-byte static ELF (phase 0). Linux aarch64 once that backend finishes Milestone 4 (string-concat).")) +
        "</div>" +
        htH2("More") +
        "<div class=" + DQ() + "grid" + DQ() + ">" +
        "<div class=" + DQ() + "card" + DQ() + ">" + htH3("84 Examples") + htP("From basics to GUI apps.") + "</div>" +
        "<div class=" + DQ() + "card" + DQ() + ">" + htH3("35 Algorithms") + htP("Sorts, DP, graphs, KMP, Dijkstra.") + "</div>" +
        "<div class=" + DQ() + "card" + DQ() + ">" + htH3("20 Tools") + htP("CLI utilities in Krypton.") + "</div>" +
        "</div>" +
        htP(htEm("Built something? Email brian@krypton-lang.org to get featured.")) +
        "</div></section>"
    emit sitePage("Programs", content)
}

// ── KryptScript page (added 2.2) ─────────────────────────────────────
// Standalone explainer for the .ks convention. Linked from every page
// via the .nav-ks button and from the downloads page.

func pageKryptScript() {
    let sampleHello =
        "#!/usr/bin/env kr" + NL() +
        "just run {" + NL() +
        "    kp(" + DQ() + "hello from a kryptscript" + DQ() + ")" + NL() +
        "}" + NL()

    let sampleArgs =
        "#!/usr/bin/env kr" + NL() +
        "// rename.ks " + DASH() + " batch-rename files matching a pattern" + NL() +
        "just run {" + NL() +
        "    if argCount() < 2 {" + NL() +
        "        kp(" + DQ() + "usage: rename.ks <from-ext> <to-ext>" + DQ() + ")" + NL() +
        "        exit(1)" + NL() +
        "    }" + NL() +
        "    let from = arg(0)" + NL() +
        "    let to   = arg(1)" + NL() +
        "    let files = shellRun(" + DQ() + "ls *." + DQ() + " + from)" + NL() +
        "    let n = lineCount(files)" + NL() +
        "    let i = 0" + NL() +
        "    while i < n {" + NL() +
        "        let f = getLine(files, i)" + NL() +
        "        let base = substring(f, 0, len(f) - len(from))" + NL() +
        "        shellRun(" + DQ() + "mv " + DQ() + " + f + " + DQ() + " " + DQ() + " + base + to)" + NL() +
        "        i = i + 1" + NL() +
        "    }" + NL() +
        "    kp(" + DQ() + "renamed " + DQ() + " + n + " + DQ() + " files" + DQ() + ")" + NL() +
        "}" + NL()

    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">New in 2.2</span>" +
        htH1("KryptScript") +
        htP("Krypton, but as a script. Same compiler, same syntax " + DASH() +
            " just a " + htCode(".ks") + " file you can " + htCode("chmod +x") +
            " and run like bash or Python.") +
        "</div>"

    let body = "<section><div class=" + DQ() + "wrap" + DQ() + ">" +

        htH2("Why " + htCode(".ks") + "?") +
        htP("Krypton has always been a great language for building libraries and compiled programs. KryptScript is the same Krypton, packaged for the moment you reach for a " + htEm("script") + " instead of a binary " + DASH() + " a one-off tool, a build step, a glue script between systems.") +
        htP("The convention is purely about naming. " + htStrong("Same compiler, same syntax, same stdlib.") + " The compiler treats " + htCode(".k") + " and " + htCode(".ks") + " identically. The split exists so a glance at a file (or a directory listing, or GitHub search) tells you the author's intent.") +

        htH2("The split") +
        "<div class=" + DQ() + "grid" + DQ() + ">" +
        "<div class=" + DQ() + "card" + DQ() + ">" +
            htH3(htCode(".k") + " " + DASH() + " library or program") +
            htP("Declares " + htCode("module foo") + " (or compiles into a program). Exports functions. No shebang. Built into a binary, then run.") +
            htPre(htCode("// math.k" + NL() + "module math" + NL() + NL() +
                "func square(x) { emit x * x }" + NL() +
                "func cube(x)   { emit x * x * x }")) +
            htP("Build: " + htCode("kcc -o math.lib math.k") + ".") +
        "</div>" +
        "<div class=" + DQ() + "card" + DQ() + " style=" + DQ() + "border:2px solid var(--primary);box-shadow:0 8px 24px rgba(119,34,255,0.18)" + DQ() + ">" +
            htH3(htCode(".ks") + " " + DASH() + " runnable script") +
            htP("Has " + htCode("just run { ... }") + " and an optional " + htCode("#!/usr/bin/env kr") + " shebang. Run directly with " + htCode("kcc -r") + " or " + htCode("chmod +x") + " " + DASH() + " no separate build step.") +
            htPre(htCode(sampleHello)) +
            htP("Run: " + htCode("kcc -r hello.ks") + ", or " + htCode("chmod +x hello.ks && ./hello.ks") + " on POSIX.") +
        "</div>" +
        "</div>" +

        htH2("When to use it") +
        htP("Reach for KryptScript whenever you'd otherwise reach for bash, PowerShell, or Python:") +
        htUl(
            htLi(htStrong("Build glue") + " " + DASH() + " orchestrating compiler flags, packaging steps, deployment.") +
            htLi(htStrong("One-off CLIs") + " " + DASH() + " a script that takes a few args, does its job, exits.") +
            htLi(htStrong("Repo tooling") + " " + DASH() + " linters, sweeps, smoke tests, test harnesses.") +
            htLi(htStrong("Codegen") + " " + DASH() + " emitting other files (HTML, SQL, config) from Krypton-defined templates.")
        ) +
        htP("All the wins: same syntax as your production Krypton code, " + htCode("import") + " anything from your project, real types and structs (no dynamic chaos), compile-time errors, and the full stdlib at your fingertips.") +

        htH2("A bigger example") +
        htP("Renaming every file with one extension to another. Drop this into " + htCode("rename.ks") + ", " + htCode("chmod +x") + ", and " + htCode("./rename.ks k ks") + ":") +
        htPre(htCode(sampleArgs)) +

        htH2("Tooling support") +
        htUl(
            htLi(htStrong("kcc") + " " + DASH() + " accepts " + htCode(".ks") + " as a source file in every mode (" + htCode("-r") + ", " + htCode("-o") + ", " + htCode("--ir") + ", " + htCode("--c") + ", " + htCode("-e") + "). Output basenames strip " + htCode(".ks") + " before " + htCode(".k") + ".") +
            htLi(htStrong("Windows installer") + " " + DASH() + " registers both " + htCode(".k") + " and " + htCode(".ks") + " under the same " + htCode("Krypton.Source") + " ProgID, so the icon and double-click action match.") +
            htLi(htStrong("VS Code &amp; Antigravity extension") + " " + DASH() + " syntax highlighting, " + htCode("kls") + "-powered diagnostics, " + htCode("KryptScript") + " alias in the language picker.") +
            htLi(htStrong("GitHub") + " " + DASH() + htCode(".gitattributes") + " paints " + htCode(".ks") + " as Krypton via linguist " + DASH() + " your script directory stops looking like shell.") +
            htLi(htStrong("Shebang") + " " + DASH() + " the " + htCode("kr") + " wrapper resolves through " + htCode("kcc -r") + " so " + htCode("#!/usr/bin/env kr") + " works on macOS and Linux.")
        ) +

        htH2("Adoption is opt-in") +
        htP("Nothing about " + htCode(".ks") + " forces existing code to change. Every " + htCode(".k") + " file in your project keeps building and running exactly as it did. Adopt " + htCode(".ks") + " when it's a clear win " + DASH() + " typically the script files that already had " + htCode("just run") + " + a shebang.") +
        htP("In the Krypton repo itself, the 2.2 rename pass converted nine script files (" + htCode("lsp/build") + ", the " + htCode("lsp/test_*") + " framing smoke-tests, and " + htCode("scripts/sweep") + " / " + htCode("check_headers") + " / " + htCode("diag_failures") + " / " + htCode("sweep_tools") + " / " + htCode("test_kbackend") + "). Libraries like " + htCode("lsp/kls.k") + " stayed " + htCode(".k") + " because they're compiled to a long-running binary, not run as scripts.") +

        htH2("Get started") +
        htP("KryptScript ships with Krypton 2.2 " + DASH() + " no separate install. If you already have Krypton, you already have it. Try:") +
        htPre(htCode("echo '#!/usr/bin/env kr" + NL() +
            "just run { kp(" + DQ() + "hi from a kryptscript" + DQ() + ") }' > hello.ks" + NL() +
            "kcc -r hello.ks")) +
        htP("Or check the " + htA("/downloads.html", "Downloads page") + " for installers, and the " + htA("/learn.html", "Learn track") + " for the full language tour.") +

        "</div></section>"

    emit sitePage("KryptScript", hero + body)
}

// Styled download button -> a direct release asset. Links go straight to the
// asset, not the /releases listing (which mis-sorts the newest tag).
func dlBtn(url, label) {
    emit htAA(htHref(url) + htStyleAttr("display:inline-block;background:var(--primary);color:#fff;padding:10px 24px;border-radius:6px;font-weight:600"), label)
}

func pageDownloads() {
    let BS = fromCharCode(92)
    // All buttons land on the same GitHub release page (tag "2.1.1"),
    // which bundles four components shipped together:
    //   - Krypton 2.1.1 toolchain (Windows installer + macOS pkg/tarball)
    //   - kweb web framework (bundled into the Windows installer)
    //   - VS Code / Google Antigravity extension 2.2.0 (KryptScript-aware)
    // Each section below calls out its specific component version. Bump
    // the tag URL when a new bundled release is cut.
    let LATEST = "https://github.com/t3m3d/krypton/releases/tag/2.1.1"
    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        "<span class=" + DQ() + "tag" + DQ() + ">Latest release: 2.1.1</span>" +
        htH1("Downloads") +
        htP("Krypton 2.1.1 toolchain (" + htCode("kcc") + " + WASM backend) for Windows and macOS, the " + htCode("kweb") + " web framework CLI on Windows, and the KryptScript-aware 2.2.0 VS Code / Google Antigravity extension " + DASH() + " all on one GitHub release.") +
        "</div>"
    let content = hero +
        "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        htP("Released May 31, 2026. A bundled release: the Krypton 2.1.1 toolchain (" + htCode("kcc") + " + WASM backend) for Windows and macOS, the " + htCode("kweb") + " web framework CLI on Windows, and the KryptScript-aware 2.2.0 VS Code / Google Antigravity extension. All assets live on " + htAA(htHref(LATEST), "one GitHub release page") + ".") +

        htH3("What's in the bundle") +
        htUl(
            htLi(htCode("krypton-2.1.1-setup.exe") + " " + DASH() + " Windows installer. Bundles " + htCode("kcc") + ", " + htCode("kweb") + ", the WASM backend, krypton_rt.dll, and " + htCode(".k") + " + " + htCode(".ks") + " file associations.") +
            htLi(htCode("krypton-2.1.1-macos-arm64.pkg") + " " + DASH() + " macOS Apple Silicon signed installer (toolchain; kweb macOS port targets 2.1.2).") +
            htLi(htCode("krypton-2.1.1-macos-arm64.tar.gz") + " " + DASH() + " macOS Apple Silicon tarball, same contents as the .pkg.") +
            htLi(htCode("krypton-language-2.2.0.vsix") + " " + DASH() + " VS Code / Antigravity extension. Adds " + htCode(".ks") + " (KryptScript) + " + htCode(".k") + " syntax and ships the " + htCode("kls") + " language server for both platforms.")
        ) +

        htH2("Windows Installer (toolchain 2.1.1 + kweb)") +
        htP("One-click install to C:" + BS + "krypton with automatic PATH configuration. Bundles " + htCode("kcc") + " (the compiler), " + htCode("kweb") + " (the web framework CLI), the WASM backend, and " + htCode(".k") + " + " + htCode(".ks") + " file associations. 2.6 MB. Windows 10/11 x64.") +
        htP(dlBtn(LATEST, "Download for Windows")) +

        htH2("macOS Apple Silicon (toolchain 2.1.1)") +
        htP("Signed-payload .pkg installer for arm64 Macs. Installs to /usr/local/krypton with " + htCode("kcc") + " on your PATH. " + htCode("kweb") + " is Windows-only in 2.1.1 " + DASH() + " the macOS port arrives in 2.1.2 once " + htCode("stdlib/fs.k") + " finishes its POSIX rewrite.") +
        htP(dlBtn(LATEST, "Download .pkg for macOS")) +
        htH3("Or install with Homebrew") +
        htPre(htCode("brew install krypton")) +
        htP("Prefer a tarball? Grab " + htAA(htHref(LATEST), htCode("krypton-2.1.1-macos-arm64.tar.gz")) + " from the release page.") +

        htH2("Krypton Web Framework (kweb)") +
        htP("kweb is a single-binary CLI that scaffolds, builds, serves, and deploys Krypton sites. The DSL stack:") +
        htUl(
            htLi(htCode("htmk") + " " + DASH() + " HTML builder written in Krypton (every tag a function).") +
            htLi(htCode("kcss") + " " + DASH() + " CSS DSL with theme tokens and breakpoints.") +
            htLi(htCode("ks") + " " + DASH() + " server-side templating helpers.") +
            htLi(htCode("server") + " + " + htCode("router") + " " + DASH() + " HTTP server and route table for serving the output.")
        ) +
        htP("Bundled inside the Windows installer at " + htCode("C:" + BS + "krypton" + BS + "kweb.exe") + ". CLI surface:") +
        htPre(htCode("kweb init <name>      # scaffold a new site" + NL() +
                     "kweb build            # render to dist/" + NL() +
                     "kweb serve [port]     # local dev server" + NL() +
                     "kweb deploy <host> <user>   # rsync dist/ over SSH")) +
        htP("On macOS / Linux for now, build from source after installing the toolchain:") +
        htPre(htCode("git clone https://github.com/t3m3d/kweb" + NL() + "cd kweb" + NL() + "kcc kweb.htk -o kweb")) +
        htP("This very site (" + htCode("krypton-lang.org") + ") is rendered by kweb, written in Krypton.") +

        htH2("Linux / BSD / Source") +
        htP("Clone and build " + DASH() + " prebuilt seeds eliminate the need for external compilers:") +
        htPre(htCode("git clone https://github.com/t3m3d/krypton" + NL() + "cd krypton" + NL() + "./build.sh")) +

        htH2("VS Code &amp; Google Antigravity Extension (2.2.0)") +
        htP("Syntax highlighting, bracket matching, code folding, and " + htCode("kls") + "-powered diagnostics + completions for Krypton (" + htCode(".k") + " libraries) and KryptScript (" + htCode(".ks") + " scripts). New in 2.2.0: full " + htCode(".ks") + " language contribution, " + htCode("KryptScript") + " language-picker alias, and refreshed " + htCode("kls") + " bundled binaries for Windows + macOS. One .vsix installs in both VS Code and Google Antigravity (a VS Code fork) " + DASH() + " Extensions panel " + fromCharCode(8594) + " Install from VSIX.") +
        htP(dlBtn(LATEST, "Download .vsix")) +

        htH2("New: KryptScript (" + htCode(".ks") + " scripts)") +
        htP("Krypton 2.2 introduces " + htCode(".ks") + " as a sibling extension for run-as-script files. Same compiler, same syntax, different use case. " + htA("/kryptscript.html", "Learn about KryptScript " + DASH() + " what it's for, how to write one, and how it relates to ") + htCode(".k") + ".") +

        htH2("Verify") +
        htP("After install, confirm the toolchain version:") +
        htPre(htCode("kcc --version    # kcc version 2.1.1")) +
        htP("And confirm the editor extension version inside VS Code / Antigravity:") +
        htPre(htCode("Extensions panel " + fromCharCode(8594) + " Krypton " + fromCharCode(8594) + " v2.2.0")) +
        "</div></section>"
    emit sitePage("Downloads", content)
}

// ── Language comparison page ─────────────────────────────────────────
// Honest, dimension-by-dimension comparison vs the other native /
// systems languages Krypton wants to compete with. Shipped flags +
// known gaps both visible — link target from the Features page.

func _yes()  { emit htElA("span", htAttr("class", "cmp-yes"),  "&#10003;") }
func _no()   { emit htElA("span", htAttr("class", "cmp-no"),   "&minus;") }
func _part() { emit htElA("span", htAttr("class", "cmp-part"), "&#9678;") }
func _todo() { emit htElA("span", htAttr("class", "cmp-todo"), "&hellip;") }

func _cmpRow(dim, c, cpp, odin, js, swift, objc, kr) {
    let cellC  = htAttr("class", "c")
    let cellKr = htAttr("class", "c kr")
    emit "<tr>" +
        htTd(dim) +
        htTdA(cellC,  c) +
        htTdA(cellC,  cpp) +
        htTdA(cellC,  odin) +
        htTdA(cellC,  js) +
        htTdA(cellC,  swift) +
        htTdA(cellC,  objc) +
        htTdA(cellKr, kr) +
        "</tr>"
}

func pageCompare() {
    let hero = "<div class=" + DQ() + "hero" + DQ() + ">" +
        "<canvas id=" + DQ() + "heroCanvas" + DQ() + "></canvas>" +
        htH1("Language Comparison") +
        htP("Where Krypton stands today vs the other native and systems-targeting languages, dimension by dimension. " +
            "We're transparent about both shipped capabilities and known gaps.") +
        "</div>"
    let head = "<thead><tr>" +
        htTh("Dimension") + htTh("C") + htTh("C++") + htTh("Odin") +
        htTh("JS") + htTh("Swift") + htTh("Obj-C") +
        htThA(htAttr("class", "kr"), "Krypton") +
        "</tr></thead>"
    let rows = "<tbody>" +
        _cmpRow("Direct native code",       _yes(), _yes(), _yes(), _no(),  _yes(), _yes(), _yes()) +
        _cmpRow("No LLVM dependency",       _yes(), _no(),  _no(),  _yes(), _no(),  _no(),  _yes()) +
        _cmpRow("Manual memory",            _yes(), _yes(), _yes(), _no(),  _part(), _part(), _part()) +
        _cmpRow("Garbage collection",       _no(),  _no(),  _no(),  _yes(), _yes(),  _yes(),  _yes()) +
        _cmpRow("Generics / templates",     _no(),  _yes(), _yes(), _part(), _yes(), _no(),  _todo()) +
        _cmpRow("Async / concurrency",      _part(),_part(),_part(),_yes(), _yes(), _part(), _todo()) +
        _cmpRow("Native threads",           _part(),_yes(), _yes(), _part(),_yes(), _yes(),  _todo()) +
        _cmpRow("Closures",                 _no(),  _yes(), _yes(), _yes(), _yes(), _part(), _yes()) +
        _cmpRow("Standard collections",     _no(),  _yes(), _yes(), _yes(), _yes(), _yes(),  _part()) +
        _cmpRow("Package manager",          _no(),  _part(),_no(),  _yes(), _yes(), _no(),   _todo()) +
        _cmpRow("Native macOS UI",          _part(),_part(),_part(),_no(),  _yes(), _yes(),  _part()) +
        _cmpRow("Native Windows UI",        _part(),_part(),_part(),_no(),  _no(),  _no(),   _yes()) +
        _cmpRow("Browser target (WASM)",    _no(),  _yes(), _yes(), _yes(), _part(),_no(),   _yes()) +
        _cmpRow("HTTP server (in stdlib)",  _no(),  _no(),  _no(),  _yes(), _yes(), _no(),   _yes()) +
        _cmpRow("Language server (LSP)",    _yes(), _yes(), _yes(), _yes(), _yes(), _yes(),  _yes()) +
        _cmpRow("Compiler written in itself", _no(), _no(), _yes(), _no(),  _no(),  _no(),   _yes()) +
        _cmpRow("Ecosystem maturity",       _yes(), _yes(), _part(),_yes(), _yes(), _yes(),  _no()) +
        "</tbody>"
    let legendCss =
        ".cmp-yes{color:#86efac;font-weight:700}" +
        ".cmp-no{color:#94a3b8}" +
        ".cmp-part{color:#fbbf24;font-weight:700}" +
        ".cmp-todo{color:#a78bfa;font-weight:700}" +
        ".cmp-table th.kr,.cmp-table td.kr{background:rgba(119,34,255,0.10)}" +
        ".cmp-table td.c{text-align:center;font-size:1.05em}" +
        ".cmp-table th{position:sticky;top:0;background:#0f172a}"
    let legend =
        "<div class=" + DQ() + "card" + DQ() + ">" +
        htH3("Legend") +
        "<p>" + _yes()  + " supported &nbsp;&nbsp; " +
                _part() + " partial &nbsp;&nbsp; " +
                _no()   + " not in this language &nbsp;&nbsp; " +
                _todo() + " on the Krypton roadmap" +
        "</p></div>"
    let table =
        "<div class=" + DQ() + "table-wrap" + DQ() + ">" +
        htTableA(htAttr("class", "cmp-table"), head + rows) +
        "</div>"
    let notes =
        htH2("How to read this") +
        htP("Krypton's design goal is " + htCode("native machine code, no LLVM, no clang") +
            " on every platform " + DASH() +
            " same target as C and Odin, with the safety net of mark-sweep GC and closures.") +
        htP("The four " + _todo() + " cells are the gaps we're actively working through: " +
            "generics, threads, async, and a package manager. The roadmap entries below sketch " +
            "the order they land in.") +
        htH3("What's already done (2026-06-01)") +
        htUl(
            htLi("Mark-sweep GC with shadow-stack rooting + freelist reuse (long-running programs stay flat).") +
            htLi("Closures with snapshot capture, " + htCode("stdlib/fp.k") + " functional core.") +
            htLi("Typed pointers (" + htCode("*u8") + ", " + htCode("*Vec3") + ") for raw-byte / struct-field fast paths.") +
            htLi("Three native backends: ELF (Linux), PE/COFF (Windows), Mach-O arm64 (macOS).") +
            htLi("WASM backend for the browser " + DASH() + " 16 tutorial lessons run byte-identical to native.") +
            htLi("Self-hosted compiler: " + htCode("kcc") + " is written in Krypton.") +
            htLi("Pure-Krypton HTTP server on macOS (" + htCode("k:server_native") + ") with zero C / zero clang.") +
            htLi("Cocoa scaffold for native macOS apps (" + htCode("k:cocoa") + ", in flight).") +
            htLi("Win32 GUI library (" + htCode("k:gui") + ", 98 widgets shipped).")
        ) +
        htH3("Roadmap to closing the gaps") +
        htUl(
            htLi(htCode("krSpawn") + " / " + htCode("krJoin") + " + atomic ops " + DASH() + " native threads on Windows " +
                "(" + htCode("CreateThread") + "), POSIX (" + htCode("pthread_create") + "). Q3 2026.") +
            htLi("Generics (Phase D of the typed-pointer work) " + DASH() +
                " " + htCode("func map[T](xs: [*T], f: (T) -> T)") + ". Q4 2026.") +
            htLi(htCode("krpm") + " package manager + central registry. Q4 2026.") +
            htLi("async/await via stackless coroutines on top of the thread substrate. 2027.") +
            htLi("DOM bindings analogous to " + htCode("k:cocoa") + " so a single " + htCode(".ks") +
                " source can target a desktop app, a CLI, and a browser page. 2027.")
        ) +
        htP(htEm("Honest take: Krypton's already credible for embedded/systems work and CLI tools. The " +
                 "competition story for app development on every platform is 12-18 months out. The " +
                 "fundamentals (small core, native everywhere, no LLVM) are sound; the gaps are " +
                 "concurrency, generics, and ecosystem."))
    let content = hero +
        "<section><div class=" + DQ() + "wrap" + DQ() + ">" +
        "<style>" + legendCss + "</style>" +
        legend +
        table +
        notes +
        "</div></section>"
    emit sitePage("Comparison", content)
}

