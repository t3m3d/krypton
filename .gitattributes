# Auto detect text files and perform LF normalization
* text=auto

# ── Krypton (.k) is the primary language ──
# Let .k files be auto-detected for now.
# Once Krypton is registered in linguist, add: *.k linguist-language=Krypton

# C++ bootstrap compiler
compiler/** linguist-language=C++

# Generated C output from the Krypton compiler
*.c linguist-generated=true

# Build system files
CMakeLists.txt linguist-vendored
build/** linguist-generated=true

# Resource files
*.rc linguist-vendored
*.res linguist-generated=true
