# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST stay LF — kernel exec rejects CRLF in shebang lines.
kr      text eol=lf
*.sh    text eol=lf
*.ks    text eol=lf

# Snek test goldens MUST stay LF — Windows core.autocrlf otherwise rewrites
# them to CRLF on commit, which then diff-fails against the LF stdout of
# every Linux-piped binary. tests/snek_smoke{,_linux}.sh compare byte-for-byte.
*.expected text eol=lf

# ── Krypton language tagging for GitHub Linguist ──────────────────────
# Krypton isn't yet in github-linguist/linguist's languages.yml — an
# upstream PR adding it is in flight (Agent M, 2026-06-04). Until that
# merges, github.com has no "Krypton" language. Rather than mislabel our
# source as Go/Lisp/KCL (all wrong), we exclude .k/.ks/.krh from the
# language bar entirely (linguist-detectable=false). The bar then reflects
# only genuinely-typed files. Once the Linguist PR lands, replace this
# block with `*.k linguist-language=Krypton` (etc.) and the bar updates.
#
# .htk → KryptonWeb HTML template — paint as HTML (it IS HTML).
# .kir → generated IR text, hidden.
*.htk  linguist-language=HTML
*.kir  linguist-generated=true

# Krypton source — no real Linguist language yet, so don't claim a wrong
# one; keep it out of the language stats until "Krypton" exists upstream.
*.k    linguist-detectable=false
*.ks   linguist-detectable=false
*.krh  linguist-detectable=false

# Pre-built bootstrap seed binaries (no source in repo, treat as vendored).
bootstrap/** linguist-vendored=true

# Compiled host binaries scattered through compiler/ (kcc-*, *_host,
# *.exe, *.dll) — vendored, not source.
compiler/**/*.exe linguist-vendored=true
compiler/**/*.dll linguist-vendored=true
compiler/**/kcc-* linguist-vendored=true
compiler/**/*_host linguist-vendored=true

# WASM artefacts under web/.
web/**/*.wasm linguist-generated=true

# Generated docs / trace blobs.
trace.txt          linguist-generated=true
*.bak              linguist-generated=true
*.bak_*            linguist-generated=true

# Resource files (Windows).
*.rc  linguist-vendored
*.res linguist-generated=true

# Anything still containing C source would land here if revived
# (currently zero C in tree).
*.c linguist-generated=true
*.h linguist-generated=true
