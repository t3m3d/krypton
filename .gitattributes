# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST stay LF — kernel exec rejects CRLF in shebang lines.
kr      text eol=lf
*.sh    text eol=lf
*.ks    text eol=lf

# ── Krypton language tagging for GitHub Linguist ──────────────────────
# Krypton isn't (yet) in github-linguist/linguist's languages.yml, so
# `linguist-language=Krypton` is currently IGNORED by GitHub — the
# attribute is harmless but invisible until we land an upstream PR
# adding Krypton (`name`, `extensions`, `type`, `ace_mode`, etc.).
# Leaving the attribute in place so the day Linguist accepts the PR,
# the bar updates automatically with no further repo edits.
#
# Meanwhile GitHub will auto-detect:
#   .k   → "K" (Arthur Whitney's K — registered owner of this ext)
#   .ks  → "KerboScript"
#   .krh → unknown (won't appear in the bar)
#   .htk → mapped to HTML (they're HTML templates with embedded {{k}})
#   .kir → generated IR text, hidden
*.k    linguist-language=Krypton
*.ks   linguist-language=Krypton
*.krh  linguist-language=Krypton
*.htk  linguist-language=HTML
*.kir  linguist-generated=true

# Force the .k / .ks / .krh tree to be counted in the language stats
# even though their painted languages aren't "default-prominent".
*.k    linguist-detectable=true
*.ks   linguist-detectable=true
*.krh  linguist-detectable=true

# Pre-built bootstrap seed binaries (no source in repo, treat as vendored).
bootstrap/** linguist-vendored=true

# Compiled host binaries scattered through compiler/ (kcc-*, *_host,
# *.exe, *.dll) — vendored, not source.
compiler/**/*.exe linguist-vendored=true
compiler/**/*.dll linguist-vendored=true
compiler/**/kcc-* linguist-vendored=true
compiler/**/*_host linguist-vendored=true

# WASM artefacts under web/.
web/**/*.wasm linguist-generated=true

# Generated docs / trace blobs.
trace.txt          linguist-generated=true
*.bak              linguist-generated=true
*.bak_*            linguist-generated=true

# Resource files (Windows).
*.rc  linguist-vendored
*.res linguist-generated=true

# Anything still containing C source would land here if revived
# (currently zero C in tree).
*.c linguist-generated=true
*.h linguist-generated=true
