# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST stay LF — kernel exec rejects CRLF in shebang lines.
kr      text eol=lf
*.sh    text eol=lf

# ── Krypton (.k libraries / .ks scripts) is the primary language ──
# Override detection so GitHub paints both .k and .ks (KryptScript, 2.2+)
# as Krypton instead of KCL or shell.
*.k   linguist-language=Krypton
*.ks  linguist-language=Krypton
*.htk linguist-language=Krypton

# C++ bootstrap compiler
compiler/** linguist-language=C++

# Generated C output from the Krypton compiler
*.c linguist-generated=true

# Build system files
CMakeLists.txt linguist-vendored
build/** linguist-generated=true

# Resource files
*.rc linguist-vendored
*.res linguist-generated=true
