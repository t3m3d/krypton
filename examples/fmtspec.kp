# f-string format specs: width + alignment + zero-pad

x = 7
y = 42
name = "ed"

# bare width (default right-align, space fill)
print(f"[{x:5}]")
print(f"[{y:5}]")

# explicit alignment
print(f"[{x:>5}]")
print(f"[{x:<5}]")

# zero-pad
print(f"[{x:05}]")
print(f"[{y:05}]")

# zero-pad with explicit right-align
print(f"[{y:0>6}]")

# spec on a name
print(f"[{name:6}]")
print(f"[{name:<6}]")
