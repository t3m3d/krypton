(* Krypton Language Grammar v3 *)
(* Version 0.7.1 — March 2026                  *)
(* Matches kompiler/compile.k implementation.  *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Program Structure                                              *)
(* ═══════════════════════════════════════════════════════════════ *)

Program       ::= TopLevel* EntryPoint ;

TopLevel      ::= FuncDecl
                | StructDecl ;

(* Entry point — exactly one required per program *)
EntryPoint    ::= ( "just" | "go" ) "run" Block ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Declarations                                                   *)
(* ═══════════════════════════════════════════════════════════════ *)

FuncDecl      ::= ( "func" | "fn" ) Identifier "(" Params? ")" Block ;
Params        ::= Identifier ( "," Identifier )* ;

(* Struct names must start with an uppercase letter *)
StructDecl    ::= ( "struct" | "class" | "type" ) UpperIdentifier "{"
                      StructField*
                  "}" ;

StructField   ::= "let" Identifier ( "=" Expr )? ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Blocks & Statements                                            *)
(* ═══════════════════════════════════════════════════════════════ *)

Block         ::= "{" Stmt* "}" ;

Stmt          ::= LetStmt
                | ConstStmt
                | FieldAssignStmt
                | AssignStmt
                | CompoundAssignStmt
                | EmitStmt
                | IfStmt
                | WhileStmt
                | DoWhileStmt
                | ForInStmt
                | MatchStmt
                | TryStmt
                | ThrowStmt
                | BreakStmt
                | ContinueStmt
                | ExprStmt ;

LetStmt            ::= "let" Identifier "=" Expr ";"? ;
ConstStmt          ::= "const" Identifier "=" Expr ";"? ;
AssignStmt         ::= Identifier "=" Expr ";"? ;
FieldAssignStmt    ::= Identifier "." Identifier "=" Expr ";"? ;
CompoundAssignStmt ::= Identifier ( "+=" | "-=" | "*=" | "/=" | "%=" ) Expr ";"? ;
EmitStmt           ::= ( "emit" | "return" ) Expr ";"? ;
BreakStmt          ::= "break" ";"? ;
ContinueStmt       ::= "continue" ";"? ;
ThrowStmt          ::= "throw" Expr ";"? ;

IfStmt        ::= "if" Expr Block
                  ( "else" "if" Expr Block )*
                  ( "else" Block )? ;

WhileStmt     ::= "while" Expr Block ;

DoWhileStmt   ::= "do" Block "while" Expr ";"? ;

ForInStmt     ::= "for" Identifier "in" Expr Block ;

MatchStmt     ::= "match" Expr "{" MatchArm* "}" ;
MatchArm      ::= ( Expr | "else" ) Block ;

TryStmt       ::= "try" Block ( "catch" Identifier? Block )? ;

ExprStmt      ::= Expr ";"? ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Expressions (lowest to highest precedence)                     *)
(* ═══════════════════════════════════════════════════════════════ *)

Expr          ::= TernaryExpr ;

TernaryExpr   ::= OrExpr ( "?" Expr ":" Expr )? ;

OrExpr        ::= AndExpr ( "||" AndExpr )* ;
AndExpr       ::= EqualityExpr ( "&&" EqualityExpr )* ;
EqualityExpr  ::= RelExpr ( ( "==" | "!=" ) RelExpr )* ;
RelExpr       ::= AddExpr ( ( "<" | ">" | "<=" | ">=" ) AddExpr )* ;
AddExpr       ::= MulExpr ( ( "+" | "-" ) MulExpr )* ;
MulExpr       ::= UnaryExpr ( ( "*" | "/" | "%" ) UnaryExpr )* ;

UnaryExpr     ::= ( "-" | "!" ) UnaryExpr
                | PostfixExpr ;

(* Postfix: string index and struct field access, chainable *)
PostfixExpr   ::= PrimaryExpr ( "[" Expr "]" | "." Identifier )* ;

PrimaryExpr   ::= IntLiteral
                | StringLiteral
                | "true"
                | "false"
                | UpperIdentifier "(" Args? ")"        (* struct constructor *)
                | UpperIdentifier "{" FieldInits? "}"  (* struct literal     *)
                | Identifier "(" Args? ")"             (* function call      *)
                | Identifier                           (* variable           *)
                | "(" Expr ")" ;                       (* grouped expression *)

FieldInits    ::= FieldInit ( "," FieldInit )* ;
FieldInit     ::= Identifier ":" Expr ;

Args          ::= Expr ( "," Expr )* ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Lexical Elements                                               *)
(* ═══════════════════════════════════════════════════════════════ *)

Comment       ::= "//" { any except newline }
                | "/*" { any } "*/" ;

Identifier      ::= Letter ( Letter | Digit | "_" )* ;
UpperIdentifier ::= "A".."Z" ( Letter | Digit | "_" )* ;

IntLiteral    ::= Digit+ ;

StringLiteral ::= '"' StringChar* '"' ;
StringChar    ::= EscapeSeq | { any except '"' and '\' } ;
EscapeSeq     ::= '\n' | '\t' | '\r' | '\\' | '\"' ;

Letter        ::= 'a'..'z' | 'A'..'Z' | '_' ;
Digit         ::= '0'..'9' ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Keywords                                                       *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  just  go  func  fn  let  const  emit  return                  *)
(*  if  else  while  do  for  in  break  continue                 *)
(*  match  struct  class  type  try  catch  throw                  *)
(*  module  import  export  true  false                            *)
(*                                                                 *)
(*  Reserved for future use:                                       *)
(*  quantum  qpute  process  prepare  measure                     *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Token Types                                                    *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  INT        integer literal        42                           *)
(*  STR        string literal         "hello"                      *)
(*  ID         identifier             myVar                        *)
(*  KW:x       keyword                if, while, func, ...         *)
(*                                                                 *)
(*  Arithmetic                                                     *)
(*  PLUS    +      MINUS    -      STAR     *                      *)
(*  SLASH   /      MOD      %                                      *)
(*                                                                 *)
(*  Compound assignment                                            *)
(*  PLUSEQ  +=     MINUSEQ  -=     STAREQ   *=                    *)
(*  SLASHEQ /=     MODEQ    %=                                     *)
(*                                                                 *)
(*  Comparison                                                     *)
(*  EQ      ==     NEQ      !=     ASSIGN   =                      *)
(*  LT      <      GT       >      LTE      <=     GTE   >=        *)
(*                                                                 *)
(*  Logical                                                        *)
(*  AND     &&     OR       ||     BANG     !                      *)
(*                                                                 *)
(*  Grouping                                                       *)
(*  LPAREN  (      RPAREN   )                                      *)
(*  LBRACE  {      RBRACE   }                                      *)
(*  LBRACK  [      RBRACK   ]                                      *)
(*                                                                 *)
(*  Other                                                          *)
(*  COMMA   ,      COLON    :      SEMI     ;                      *)
(*  DOT     .      QUESTION ?      ARROW    ->                     *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Type System & Truthiness                                       *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  All values are strings at runtime.                             *)
(*    Numbers  →  "42", "-3"                                       *)
(*    Booleans →  "1" (true), "0" (false)                          *)
(*    Strings  →  as-is                                            *)
(*                                                                 *)
(*  A value is falsy if it is "", "0", or "false".                 *)
(*  All other values are truthy.                                   *)
(*                                                                 *)
(*  The + operator is overloaded: if both operands are numeric     *)
(*  strings it performs addition; otherwise concatenation.         *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

