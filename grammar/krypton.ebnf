(* Krypton Language Grammar *)
(* Version 1.6.0 — May 2026                       *)
(* Matches compiler/compile.k implementation.     *)
(* Human-readable companion: docs/spec/grammar.md *)
(* Function reference:        docs/spec/functions.md *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Program Structure                                              *)
(* ═══════════════════════════════════════════════════════════════ *)

Program       ::= ModuleDecl? TopLevel* EntryPoint? ;

ModuleDecl    ::= "module" Identifier ;

TopLevel      ::= FuncDecl
                | CallbackDecl
                | StructDecl
                | ImportStmt
                | ExportDecl
                | JxtBlock
                | GlobalLet ;

ImportStmt    ::= "import" StringLiteral ;
ExportDecl    ::= "export" ( FuncDecl | StructDecl | Identifier ) ;
GlobalLet     ::= ( "let" | "const" ) Identifier ( ":" Type )? "=" Expr ";"? ;

(* Entry point — at most one per program. Library modules omit it. *)
EntryPoint    ::= ( "just" | "go" ) "run" Block ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  jxt — header / module include block                            *)
(* ═══════════════════════════════════════════════════════════════ *)

(* Two equivalent forms. The bracketless form (1.4.0+) treats every    *)
(* `inc "..."` line as a member; the include type is inferred from the *)
(* file extension (.k → Krypton module, .h / .krh → C header). The     *)
(* block ends at the first non-`inc` token.                            *)
JxtBlock      ::= "jxt" "{" JxtItem* "}"
                | "jxt" JxtIncLine+ ;
JxtItem       ::= ( "k" | "c" | "t" ) StringLiteral ;
JxtIncLine    ::= "inc" StringLiteral ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Declarations                                                   *)
(* ═══════════════════════════════════════════════════════════════ *)

FuncDecl      ::= ( "func" | "fn" ) Identifier "(" Params? ")"
                  ( "->" Type )? Block ;

(* `callback` marks a function as exposed to C code as a raw function  *)
(* pointer (used by funcptr() and DLL callback ABIs).                  *)
CallbackDecl  ::= "callback" FuncDecl ;

Params        ::= Param ( "," Param )* ;
Param         ::= Identifier ( ":" Type )? ;

Type          ::= Identifier ( "[" Type "]" )? ;

(* Struct names must start with an uppercase letter.                   *)
StructDecl    ::= ( "struct" | "class" | "type" ) UpperIdentifier "{"
                      StructField*
                  "}" ;

StructField   ::= "let" Identifier ( ":" Type )? ( "=" Expr )? ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Blocks & Statements                                            *)
(* ═══════════════════════════════════════════════════════════════ *)

Block         ::= "{" Stmt* "}" ;

Stmt          ::= LetStmt
                | ConstStmt
                | NestedFuncDecl
                | FieldAssignStmt
                | IndexAssignStmt
                | AssignStmt
                | CompoundAssignStmt
                | IncDecStmt
                | EmitStmt
                | IfStmt
                | WhileStmt
                | DoWhileStmt
                | ForInStmt
                | MatchStmt
                | TryStmt
                | ThrowStmt
                | BreakStmt
                | ContinueStmt
                | ExprStmt ;

LetStmt            ::= "let"   Identifier ( ":" Type )? "=" Expr ";"? ;
ConstStmt          ::= "const" Identifier ( ":" Type )? "=" Expr ";"? ;

(* Nested funcs are hoisted to file-scope FUNCs by the IR walk.        *)
(* Krypton has no closures, so a nested func is semantically a sibling.*)
NestedFuncDecl     ::= FuncDecl ;

AssignStmt         ::= Identifier "=" Expr ";"? ;
FieldAssignStmt    ::= Identifier "." Identifier "=" Expr ";"? ;
IndexAssignStmt    ::= Identifier "[" Expr "]" "=" Expr ";"? ;
CompoundAssignStmt ::= Identifier ( "+=" | "-=" | "*=" | "/=" | "%=" ) Expr ";"? ;
IncDecStmt         ::= Identifier ( "++" | "--" ) ";"?
                     | ( "++" | "--" ) Identifier ";"? ;

EmitStmt           ::= ( "emit" | "return" ) Expr? ";"? ;
BreakStmt          ::= "break" ";"? ;
ContinueStmt       ::= "continue" ";"? ;
ThrowStmt          ::= "throw" Expr ";"? ;

IfStmt        ::= "if" Expr Block
                  ( "else" "if" Expr Block )*
                  ( "else" Block )? ;

WhileStmt     ::= "while" Expr Block ;
DoWhileStmt   ::= "do" Block "while" Expr ";"? ;
ForInStmt     ::= "for" Identifier "in" Expr Block ;

MatchStmt     ::= "match" Expr "{" MatchArm* "}" ;
MatchArm      ::= ( Expr | "else" ) Block ;

TryStmt       ::= "try" Block ( "catch" Identifier? Block )? ;

ExprStmt      ::= Expr ";"? ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Expressions (lowest to highest precedence)                     *)
(* ═══════════════════════════════════════════════════════════════ *)

Expr          ::= TernaryExpr ;

TernaryExpr   ::= OrExpr ( "?" Expr ":" Expr )? ;

OrExpr        ::= AndExpr      ( "||" AndExpr )* ;
AndExpr       ::= EqualityExpr ( "&&" EqualityExpr )* ;
EqualityExpr  ::= RelExpr      ( ( "==" | "!=" ) RelExpr )* ;
RelExpr       ::= AddExpr      ( ( "<" | ">" | "<=" | ">=" ) AddExpr )* ;
AddExpr       ::= MulExpr      ( ( "+" | "-" ) MulExpr )* ;
MulExpr       ::= UnaryExpr    ( ( "*" | "/" | "%" ) UnaryExpr )* ;

UnaryExpr     ::= ( "-" | "!" ) UnaryExpr
                | PostfixExpr ;

(* Postfix: index, field access, and function-call chaining.           *)
PostfixExpr   ::= PrimaryExpr ( "[" Expr "]"
                              | "." Identifier
                              | "(" Args? ")"
                              )* ;

PrimaryExpr   ::= IntLiteral
                | StringLiteral
                | InterpString
                | "true"
                | "false"
                | "null"
                | ListLiteral
                | Lambda
                | UpperIdentifier "(" Args? ")"        (* struct constructor *)
                | UpperIdentifier "{" FieldInits? "}"  (* struct literal     *)
                | Identifier "(" Args? ")"             (* function call      *)
                | Identifier                           (* variable           *)
                | "(" Expr ")" ;                       (* grouped expression *)

ListLiteral   ::= "[" ( Expr ( "," Expr )* )? "]" ;

(* Lambdas use the same FuncDecl shape but anonymous.                  *)
Lambda        ::= ( "func" | "fn" ) "(" Params? ")"
                  ( "->" Type )? Block ;

FieldInits    ::= FieldInit ( "," FieldInit )* ;
FieldInit     ::= Identifier ":" Expr ;

Args          ::= Expr ( "," Expr )* ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Lexical Elements                                               *)
(* ═══════════════════════════════════════════════════════════════ *)

Comment       ::= "//" { any except newline }
                | "/*" { any } "*/" ;

Identifier      ::= Letter ( Letter | Digit | "_" )* ;
UpperIdentifier ::= "A".."Z" ( Letter | Digit | "_" )* ;

IntLiteral    ::= Digit+
                | "0x" HexDigit+
                | "0X" HexDigit+ ;

StringLiteral ::= '"' StringChar* '"' ;
StringChar    ::= EscapeSeq | { any except '"' and '\' } ;
EscapeSeq     ::= '\n' | '\t' | '\r' | '\\' | '\"' | "\'" ;

(* Backtick interpolation strings: `hello {name}!`                     *)
(* Embedded {Expr} substitutions are evaluated and stringified.        *)
InterpString  ::= '`' InterpChar* '`' ;
InterpChar    ::= EscapeSeq
                | "{" Expr "}"
                | { any except '`' and '\' and '{' } ;

Letter        ::= 'a'..'z' | 'A'..'Z' | '_' ;
Digit         ::= '0'..'9' ;
HexDigit      ::= '0'..'9' | 'a'..'f' | 'A'..'F' ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Operator Precedence (lowest → highest)                         *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*    10  Assignment    =  +=  -=  *=  /=  %=    (right-assoc)     *)
(*     9  Ternary       ? :                       (right-assoc)     *)
(*     8  Logical OR    ||                                          *)
(*     7  Logical AND   &&                                          *)
(*     6  Equality      ==  !=                                      *)
(*     5  Relational    <  >  <=  >=                                *)
(*     4  Additive      +  -                                        *)
(*     3  Multiplicative *  /  %                                    *)
(*     2  Unary         -  !                       (right-assoc)     *)
(*     1  Postfix       [i]  .field  f()                            *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Keywords                                                       *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*   Entry / declaration                                           *)
(*     just   go   func   fn   let   const                         *)
(*     module import export jxt                                    *)
(*     struct class type   callback                                *)
(*                                                                 *)
(*   Control flow                                                  *)
(*     if  else  while  do  loop  until                            *)
(*     for in match break continue                                 *)
(*     try catch throw   emit return                               *)
(*                                                                 *)
(*   Constants                                                     *)
(*     true   false   null                                         *)
(*                                                                 *)
(*   Reserved for future use (quantum backend)                     *)
(*     quantum  qpute  process  prepare  measure                   *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Token Types                                                    *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*   Atoms                                                         *)
(*     INT:n     integer literal      42, 0xFF                     *)
(*     STR:s     string literal       "hello"                      *)
(*     INTERP:s  backtick interp str  `hello {name}`               *)
(*     ID:name   identifier           myVar                        *)
(*     KW:word   keyword              if, while, func, …           *)
(*     CBLOCK    inline C block       cfunc { ... }                *)
(*                                                                 *)
(*   Arithmetic                                                    *)
(*     PLUS    +      MINUS    -      STAR     *                   *)
(*     SLASH   /      MOD      %                                   *)
(*                                                                 *)
(*   Compound assignment / inc-dec                                 *)
(*     PLUSEQ  +=     MINUSEQ  -=     STAREQ   *=                  *)
(*     SLASHEQ /=     MODEQ    %=                                  *)
(*     PLUSPLUS  ++   MINUSMINUS --                                *)
(*                                                                 *)
(*   Comparison / assignment                                       *)
(*     EQ      ==     NEQ      !=     ASSIGN   =                   *)
(*     LT      <      GT       >      LTE  <=  GTE   >=            *)
(*                                                                 *)
(*   Logical                                                       *)
(*     AND     &&     OR       ||     BANG     !                   *)
(*                                                                 *)
(*   Grouping                                                      *)
(*     LPAREN  (      RPAREN   )                                   *)
(*     LBRACE  {      RBRACE   }                                   *)
(*     LBRACK  [      RBRACK   ]                                   *)
(*                                                                 *)
(*   Punctuation                                                   *)
(*     COMMA   ,      COLON    :      SEMI     ;                   *)
(*     DOT     .      QUESTION ?      ARROW    ->                  *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Type System & Truthiness                                       *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*   All values are strings at runtime.                            *)
(*     Numbers  →  "42", "-3"                                      *)
(*     Booleans →  "1" (true), "0" (false)                         *)
(*     null     →  "" (empty string)                               *)
(*     Strings  →  as-is                                           *)
(*                                                                 *)
(*   A value is FALSY if it is "", "0", or "false".                *)
(*   Everything else is truthy.                                    *)
(*                                                                 *)
(*   The `+` operator is overloaded: if BOTH operands look numeric *)
(*   it performs integer addition, otherwise concatenation.        *)
(*   This means "1" + "2" → "3", not "12". Use sbAppend to force   *)
(*   string concat of digit-only tokens.                           *)
(*                                                                 *)
(*   Native pipeline: values < 0x40000000 (1 GiB) are stored as    *)
(*   small integers, ≥ 0x40000000 are heap pointers. Integers at   *)
(*   or above 1 GiB are not safe in the native pipeline.           *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* See docs/spec/functions.md for the full built-in function       *)
(* reference, with each entry tagged (native) or (C path).         *)
