(* Krypton Language Grammar v2 — krypton.ebnf *)
(* Matches the self-hosting compiler (kompiler/) implementation. *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Program Structure                                              *)
(* ═══════════════════════════════════════════════════════════════ *)

Program       ::= TopLevel* ;

TopLevel      ::= FuncDecl
                | EntryPoint ;

(* Entry point — exactly one required per program *)
EntryPoint    ::= ( "just" | "go" ) "run" Block ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Functions                                                      *)
(* ═══════════════════════════════════════════════════════════════ *)

FuncDecl      ::= "func" Identifier "(" Params? ")" Block ;
Params        ::= Identifier ( "," Identifier )* ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Blocks & Statements                                            *)
(* ═══════════════════════════════════════════════════════════════ *)

Block         ::= "{" Stmt* "}" ;

Stmt          ::= LetStmt
                | AssignStmt
                | EmitStmt
                | IfStmt
                | WhileStmt
                | BreakStmt
                | ExprStmt ;

LetStmt       ::= "let" Identifier "=" Expr ;
AssignStmt    ::= Identifier "=" Expr ;
EmitStmt      ::= "emit" Expr ;
BreakStmt     ::= "break" ;

IfStmt        ::= "if" Expr Block
                   ( "else" "if" Expr Block )*
                   ( "else" Block )? ;

WhileStmt     ::= "while" Expr Block ;

ExprStmt      ::= Expr ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Expressions (lowest to highest precedence)                     *)
(* ═══════════════════════════════════════════════════════════════ *)

Expr          ::= OrExpr ;

OrExpr        ::= AndExpr ( "||" AndExpr )* ;
AndExpr       ::= EqualityExpr ( "&&" EqualityExpr )* ;
EqualityExpr  ::= RelExpr ( ( "==" | "!=" ) RelExpr )* ;
RelExpr       ::= AddExpr ( ( "<" | ">" | "<=" | ">=" ) AddExpr )* ;
AddExpr       ::= MulExpr ( ( "+" | "-" ) MulExpr )* ;
MulExpr       ::= UnaryExpr ( ( "*" | "/" | "%" ) UnaryExpr )* ;

UnaryExpr     ::= ( "-" | "!" ) UnaryExpr
                | PostfixExpr ;

PostfixExpr   ::= PrimaryExpr ( "[" Expr "]" )* ;

PrimaryExpr   ::= IntLiteral
                | StringLiteral
                | "true" | "false"
                | CallExpr
                | Identifier
                | "(" Expr ")" ;

CallExpr      ::= Identifier "(" Args? ")" ;
Args          ::= Expr ( "," Expr )* ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Lexical Elements                                               *)
(* ═══════════════════════════════════════════════════════════════ *)

Comment       ::= "//" { any except newline }
                | "/*" { any } "*/" ;

Identifier    ::= Letter ( Letter | Digit | "_" )* ;

IntLiteral    ::= Digit+ ;

StringLiteral ::= '"' StringChar* '"' ;
StringChar    ::= EscapeSeq | { any except '"' and '\' } ;
EscapeSeq     ::= '\n' | '\t' | '\r' | '\\' | '\"' ;

Letter        ::= 'a'..'z' | 'A'..'Z' | '_' ;
Digit         ::= '0'..'9' ;

(* ═══════════════════════════════════════════════════════════════ *)
(*  Token Types                                                    *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  INT       integer literal          42                          *)
(*  STR       string literal           "hello"                     *)
(*  ID        identifier               myVar                       *)
(*  KW:x      keyword                  if, while, func, ...        *)
(*  PLUS      +       MINUS    -       STAR     *                  *)
(*  SLASH     /       PERCENT  %       BANG     !                  *)
(*  EQ        ==      NEQ      !=      ASSIGN   =                 *)
(*  LT        <       GT       >       LTE      <=                *)
(*  GTE       >=      AND      &&      OR       ||                *)
(*  LPAREN    (       RPAREN   )                                   *)
(*  LBRACE    {       RBRACE   }                                   *)
(*  LBRACK    [       RBRACK   ]                                   *)
(*  COMMA     ,       COLON    :       SEMI     ;                  *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Builtin Functions                                              *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  I/O                                                            *)
(*    print(s)              Write s + newline to stdout             *)
(*    kp(s)                 Alias for print                        *)
(*    readFile(path)        Read file contents as string           *)
(*    arg(index)            Command-line argument by index         *)
(*    argCount()            Number of command-line arguments       *)
(*                                                                 *)
(*  String operations                                              *)
(*    len(s)                String length                          *)
(*    substring(s, st, en)  Substring from st to en (exclusive)    *)
(*    split(s, index)       Split on comma, return part by index   *)
(*    startsWith(s, pfx)    "1" if s starts with pfx, else "0"    *)
(*    getLine(s, index)     Get line by index from multiline str   *)
(*    lineCount(s)          Number of lines in string              *)
(*    count(s)              Alias for lineCount                    *)
(*                                                                 *)
(*  Type conversion                                                *)
(*    toInt(s)              Parse string to integer string          *)
(*                                                                 *)
(*  StringBuilder                                                  *)
(*    sbNew()               Create new string builder              *)
(*    sbAppend(sb, s)       Append s to builder, return handle     *)
(*    sbToString(sb)        Finalize builder to string             *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)

(* ═══════════════════════════════════════════════════════════════ *)
(*  Type System & Truthiness                                       *)
(* ═══════════════════════════════════════════════════════════════ *)
(*                                                                 *)
(*  All values are strings at runtime.                             *)
(*    Numbers  →  "42", "-3"                                       *)
(*    Booleans →  "1" (true), "0" (false)                          *)
(*    Strings  →  as-is                                            *)
(*                                                                 *)
(*  A value is falsy if it is "", "0", or "false".                 *)
(*  All other values are truthy.                                   *)
(*                                                                 *)
(*  The + operator is overloaded: if both operands are numeric     *)
(*  strings it performs addition; otherwise concatenation.          *)
(*                                                                 *)
(* ═══════════════════════════════════════════════════════════════ *)